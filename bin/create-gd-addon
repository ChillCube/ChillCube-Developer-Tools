#!/usr/bin/env bash
set -e

echo "🧊 ChillCube Addon Initializer"
echo "--------------------------------------------------"

# 1. Setup Directory Structure
if [ -f "project.godot" ]; then
    echo "🏠 Godot project detected. Addon will be its own repo inside addons/."
    BASE_DIR="addons"
else
    echo "⚠️  No project.godot found. Creating standalone addon directory."
    BASE_DIR="."
fi

# 2. Collect Addon Info
read -p "🏷️  Addon Name: " ADDON_NAME
read -p "📝 Description: " ADDON_DESC
read -p "👤 Author Name: " AUTHOR_NAME
YEAR=$(date +%Y)

# Convert Name to folder-style (The exact name used for Folder and GitHub Repo)
SAFE_NAME=$(echo "$ADDON_NAME" | tr '[:upper:]' '[:lower:]' | tr ' ' '_')
TARGET_PATH="$BASE_DIR/$SAFE_NAME"

# 3. Create Folder and INITIALIZE GIT
echo "📂 Creating folder at $TARGET_PATH..."
mkdir -p "$TARGET_PATH"
cd "$TARGET_PATH"

echo "🔧 Initializing Git repository..."
git init -q
git branch -m main  # Force branch name to 'main'

# 4. Create .gitignore
cat <<EOF > .gitignore
.godot/
*.import/
*.tmp
EOF

# 5. Create Addon Files
touch "DEPENDENCIES.txt"

cat <<EOF > "plugin.cfg"
[plugin]
name="$ADDON_NAME"
description="$ADDON_DESC"
author="$AUTHOR_NAME"
version="0.1.0"
script=""
EOF

# 6. Apply Boost Software License 1.0
echo "⚖️  Downloading Boost Software License..."
curl -sSL "https://www.boost.org/LICENSE_1_0.txt" -o "LICENSE"

# 7. Generate README
echo "📥 Fetching and customizing README template..."
TEMPLATE_URL="https://raw.githubusercontent.com/ChillCube/ChillCube-Developer-Tools/main/templates/README_GODOT_ADDON_TEMPLATE.md"
curl -sSL "$TEMPLATE_URL" -o "README.md"

sed -i "s/{{NAME}}/$ADDON_NAME/g" "README.md"
sed -i "s/{{DESC}}/$ADDON_DESC/g" "README.md"
sed -i "s/{{AUTHOR}}/$AUTHOR_NAME/g" "README.md"
sed -i "s/{{YEAR}}/$YEAR/g" "README.md"

# 8. Finalize Git Tracking & GitHub Org
echo "--------------------------------------------------"
echo "📦 Staging files..."
git add .
git commit -m "initial: initialize $ADDON_NAME as a ChillCube addon"

if command -v gh &> /dev/null && gh auth status &> /dev/null; then
    # Removed the "addon-" prefix here
    echo "🌐 Creating GitHub repository: ChillCube/$SAFE_NAME"
    gh repo create "ChillCube/$SAFE_NAME" --public --source=. --remote=origin --push
else
    echo "⚠️  Note: Local repo created, but GitHub push skipped."
fi

echo "--------------------------------------------------"
echo "✅ Done! Repo live at https://github.com/ChillCube/$SAFE_NAME"
