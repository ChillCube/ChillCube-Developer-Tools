#!/usr/bin/env bash
set -e

echo "🧊 Chillcube Addon Initializer (Project Mode)"
echo "--------------------------------------------------"

# 1. Detect Godot Project
if [ -f "project.godot" ]; then
    echo "🏠 Godot project detected in current directory."
    BASE_DIR="addons"
else
    echo "⚠️  No project.godot found. Creating a standalone repo instead."
    read -p "📂 Enter new repository folder name: " REPO_NAME
    mkdir -p "$REPO_NAME"
    cd "$REPO_NAME"
    git init -q
    BASE_DIR="addons"
fi

# 2. Collect Addon Info
read -p "🏷️  Addon Name: " ADDON_NAME
read -p "📝 Description: " ADDON_DESC
read -p "👤 Author Name: " AUTHOR_NAME
read -p "📦 Dependencies (comma separated): " DEPS
YEAR=$(date +%Y)

# Convert Name to folder-style (e.g., "Chill Inventory" -> "chill_inventory")
# Godot prefers underscores for internal addon folders
SAFE_NAME=$(echo "$ADDON_NAME" | tr '[:upper:]' '[:lower:]' | tr ' ' '_')
TARGET_PATH="$BASE_DIR/$SAFE_NAME"

# 3. Create Structure
echo "📂 Creating $TARGET_PATH..."
mkdir -p "$TARGET_PATH"

# 4. Create DEPENDENCIES.txt
echo "📄 Generating DEPENDENCIES.txt..."
{
    if [ -z "$DEPS" ]; then echo "None"; else echo "$DEPS" | tr ',' '\n' | sed 's/^[[:space:]]*//; s/^/ - /'; fi
} > "$TARGET_PATH/DEPENDENCIES.txt"

# 5. Create plugin.cfg
echo "⚙️  Generating plugin.cfg..."
cat <<EOF > "$TARGET_PATH/plugin.cfg"
[plugin]
name="$ADDON_NAME"
description="$ADDON_DESC"
author="$AUTHOR_NAME"
version="0.1.0"
script=""
EOF

# 6. Fetch License (README is only created if in Standalone mode)
echo "⚖️  Applying BSL-1.1 License..."
curl -s "https://raw.githubusercontent.com/MariaDBCorporation/BSL-1.1/master/BSL-1.1.txt" -o "$TARGET_PATH/LICENSE"

if [ ! -f "project.godot" ]; then
    echo "📥 Fetching README template for standalone repo..."
    TEMPLATE_URL="https://raw.githubusercontent.com/ChillCube/ChillCube-Developer-Tools/main/templates/README_TEMPLATE.md"
    curl -s "$TEMPLATE_URL" -o README.md
    sed -i "s/{{NAME}}/$ADDON_NAME/g" README.md
    sed -i "s/{{DESC}}/$ADDON_DESC/g" README.md
    sed -i "s/{{AUTHOR}}/$AUTHOR_NAME/g" README.md
    sed -i "s/{{YEAR}}/$YEAR/g" README.md
fi

echo "--------------------------------------------------"
echo "✅ Done! Addon initialized at: $TARGET_PATH"
