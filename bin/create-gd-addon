#!/usr/bin/env bash
set -e

echo "🧊 ChillCube Addon Initializer"
echo "--------------------------------------------------"

# Detect Mode
if [ -f "project.godot" ]; then
    echo "🏠 Godot project detected."
    BASE_DIR="addons"
    IS_STANDALONE=false
else
    echo "⚠️  No project.godot found. Creating standalone repository."
    read -p "📂 Enter repository name: " REPO_NAME
    mkdir -p "$REPO_NAME"
    cd "$REPO_NAME"
    
    # FORCE GIT INIT HERE
    git init
    echo "✅ Git repository initialized in $(pwd)"
    
    # Create Godot-friendly .gitignore
    cat <<EOF > .gitignore
.godot/
*.import/
export_presets.cfg
.utest/
*.tmp
EOF
    
    BASE_DIR="addons"
    IS_STANDALONE=true
fi

# Collect Addon Info
read -p "🏷️  Addon Name: " ADDON_NAME
read -p "📝 Description: " ADDON_DESC
read -p "👤 Author Name: " AUTHOR_NAME
YEAR=$(date +%Y)

SAFE_NAME=$(echo "$ADDON_NAME" | tr '[:upper:]' '[:lower:]' | tr ' ' '_')
TARGET_PATH="$BASE_DIR/$SAFE_NAME"

# 3. Create Structure
mkdir -p "$TARGET_PATH"

# 4. Create Files
touch "$TARGET_PATH/DEPENDENCIES.txt"

cat <<EOF > "$TARGET_PATH/plugin.cfg"
[plugin]
name="$ADDON_NAME"
description="$ADDON_DESC"
author="$AUTHOR_NAME"
version="0.1.0"
script=""
EOF

# License & README
curl -s "https://raw.githubusercontent.com/MariaDBCorporation/BSL-1.1/master/BSL-1.1.txt" -o "$TARGET_PATH/LICENSE"

TEMPLATE_URL="https://raw.githubusercontent.com/ChillCube/ChillCube-Developer-Tools/main/templates/README_TEMPLATE.md"
README_DEST=$([ "$IS_STANDALONE" = true ] && echo "README.md" || echo "$TARGET_PATH/README.md")

curl -s "$TEMPLATE_URL" -o "$README_DEST"

sed -i "s/{{NAME}}/$ADDON_NAME/g" "$README_DEST"
sed -i "s/{{DESC}}/$ADDON_DESC/g" "$README_DEST"
sed -i "s/{{AUTHOR}}/$AUTHOR_NAME/g" "$README_DEST"
sed -i "s/{{YEAR}}/$YEAR/g" "$README_DEST"

# Finalize Git & GitHub
if [ "$IS_STANDALONE" = true ]; then
    echo "--------------------------------------------------"
    git add .
    git commit -m "initial: initialize ChillCube addon structure"
    
    if command -v gh &> /dev/null && gh auth status &> /dev/null; then
        echo "🌐 Creating GitHub repository under ChillCube..."
        gh repo create "ChillCube/$REPO_NAME" --public --source=. --remote=origin --push
    else
        echo "⚠️  Note: GitHub repo not created (gh CLI missing or not logged in)."
    fi
fi

echo "--------------------------------------------------"
echo "✅ Done! Addon initialized at: $TARGET_PATH"
