#!/bin/bash
set -e  # Exit immediately if any command fails

echo "🧊 Chillcube Git Push Initializing..."

# Show Status
echo "--------------------------------------------------"
echo "📍 Current Branch: $(git branch --show-current)"
git status -s
echo "--------------------------------------------------"

# Target Branch
CURRENT_BR=$(git branch --show-current)
read -p "🎯 Target branch (default: $CURRENT_BR): " TARGET_BRANCH
TARGET_BRANCH=${TARGET_BRANCH:-$CURRENT_BR}

# Stage and Commit FIRST
# This is required for a clean rebase
git add .
if ! git diff-index --quiet HEAD; then
    read -p "📝 Enter commit message: " COMMIT_MSG
    COMMIT_MSG=${COMMIT_MSG:-"update: tools sync"}
    git commit -m "$COMMIT_MSG"
fi

# Sync with Remote
echo "🔄 Fetching and Rebasin'..."
git fetch origin
# Rebase puts your local commits on top of origin's commits
git rebase "origin/$TARGET_BRANCH"

# Permission Insurance (Handles missing folders/files gracefully)
if [ -d "bin" ] && [ "$(ls -A bin 2>/dev/null)" ]; then
    echo "🛡️  Ensuring bin/ is executable..."
    git update-index --add --chmod=+x bin/* [cite: 7]
fi

if [ -f "install.sh" ]; then
    echo "🛡️  Ensuring install.sh is executable..."
    git update-index --add --chmod=+x install.sh [cite: 8]
fi

# Final Push
# If permissions changed the index, we amend the previous commit
if ! git diff-index --quiet HEAD; then
    git commit --amend --no-edit
fi

git push origin "$TARGET_BRANCH"

echo "--------------------------------------------------"
echo "✅ Successfully pushed to $TARGET_BRANCH!"
