#!/bin/bash

# --- Chillcube Addon Remover ---
# Usage: remove-gd-addon <addon_name>

TARGET_ADDON=$1

if [ -z "$TARGET_ADDON" ]; then
    echo "Usage: remove-gd-addon <addon_name>"
    echo "Example: remove-gd-addon godot-git-plugin"
    exit 1
fi

ADDON_PATH="addons/$TARGET_ADDON"

if [ ! -d "$ADDON_PATH" ]; then
    echo "❌ Addon '$TARGET_ADDON' not found in addons/ directory."
    exit 1
fi

echo "🧊 Preparing to remove: $TARGET_ADDON"

# Collect all dependencies of the addon we ARE deleting
DEPS_TO_REMOVE=()
DEP_FILE="$ADDON_PATH/DEPENDENCIES.txt"
if [ -f "$DEP_FILE" ]; then
    while read -r dep_url || [ -n "$dep_url" ]; do
        [[ -z "$dep_url" || "$dep_url" =~ ^# ]] && continue
        dep_name=$(basename "$dep_url" .git)
        DEPS_TO_REMOVE+=("$dep_name")
    done < "$DEP_FILE"
fi

# Identify dependencies required by OTHER addons (the ones staying)
REQUIRED_BY_OTHERS=()
for other_addon in addons/*; do
    other_name=$(basename "$other_addon")
    
    # Skip the one we are deleting and non-directories
    if [ "$other_name" == "$TARGET_ADDON" ] || [ ! -d "$other_addon" ]; then
        continue
    fi
    
    OTHER_DEP_FILE="$other_addon/DEPENDENCIES.txt"
    if [ -f "$OTHER_DEP_FILE" ]; then
        while read -r dep_url || [ -n "$dep_url" ]; do
            [[ -z "$dep_url" || "$dep_url" =~ ^# ]] && continue
            req_name=$(basename "$dep_url" .git)
            REQUIRED_BY_OTHERS+=("$req_name")
        done < "$OTHER_DEP_FILE"
    fi
done

# Delete the main addon
echo "🗑️  Removing main addon: $TARGET_ADDON"
rm -rf "$ADDON_PATH"

# Delete dependencies ONLY if no one else needs them
for dep in "${DEPS_TO_REMOVE[@]}"; do
    # Check if 'dep' exists in the 'REQUIRED_BY_OTHERS' list
    is_required=false
    for req in "${REQUIRED_BY_OTHERS[@]}"; do
        if [ "$dep" == "$req" ]; then
            is_required=true
            break
        fi
    done

    if [ "$is_required" = true ]; then
        echo "⏭️  Skipping dependency '$dep' (still required by another addon)."
    else
        if [ -d "addons/$dep" ]; then
            echo "🗑️  Removing unused dependency: $dep"
            rm -rf "addons/$dep"
        fi
    fi
done

echo "✅ Cleanup complete."
