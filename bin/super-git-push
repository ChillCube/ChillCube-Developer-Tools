#!/bin/bash
set -e

# --- Chillcube Smart Push ---
echo "🧊 Chillcube Git Sync Initializing..."
echo "--------------------------------------------------"

# 1. Get current branch
CURRENT_BR=$(git branch --show-current)
echo "📍 Current Branch: $CURRENT_BR"

# 2. Stage all changes
# Resetting first clears the index of any ghost paths or errors
git reset
git add .

# 3. Ensure binaries are executable in the Git Index
if [ -d "bin" ]; then
    echo "🛡️  Ensuring bin/ files are executable..."
    # Using find prevents shell expansion errors from comments
    find bin/ -type f -exec git update-index --chmod=+x {} +
fi

if [ -f "install.sh" ]; then
    git update-index --chmod=+x install.sh
fi

# 4. Commit
read -p "📝 Enter commit message: " COMMIT_MSG
COMMIT_MSG=${COMMIT_MSG:-"update: chillcube tools sync"}
git commit -m "$COMMIT_MSG"

# 5. Sync and Push
read -p "🎯 Target branch (default: $CURRENT_BR): " TARGET_BRANCH
TARGET_BRANCH=${TARGET_BRANCH:-$CURRENT_BR}

echo "🔄 Fetching and Rebasin'..."
git pull origin "$TARGET_BRANCH" --rebase
git push origin "$TARGET_BRANCH"

echo "--------------------------------------------------"
echo "✅ Successfully pushed to $TARGET_BRANCH!"te."
