#!/bin/bash
set -e

# --- Chillcube Smart Push ---
echo "🧊 Chillcube Git Sync Initializing..."
echo "--------------------------------------------------"

# 1. Get current status
CURRENT_BR=$(git branch --show-current)
echo "📍 Currently on branch: $CURRENT_BR"

# 2. Stage everything and fix permissions
# We use -A to ensure deletions and new files are all caught
git add -A

if [ -d "bin" ]; then
    echo "🛡️  Ensuring bin/ files are executable..."
    find bin/ -type f -exec git update-index --chmod=+x {} +
fi

# 3. Commit
read -p "📝 Enter commit message: " COMMIT_MSG
COMMIT_MSG=${COMMIT_MSG:-"update: chillcube tools sync"}

# Only commit if there are actually changes to avoid "nothing to commit" errors
if ! git diff-index --quiet HEAD --; then
    git commit -m "$COMMIT_MSG"
else
    echo "empty: No new changes to commit."
fi

# 4. Branch Selection
echo "--------------------------------------------------"
echo "🌍 Available Remote Branches:"
git fetch --prune --quiet
# Lists remote branches clearly
git branch -r | sed 's/origin\///' | grep -v "HEAD" | sort -u
echo "--------------------------------------------------"

read -p "🎯 Target branch (default: $CURRENT_BR): " TARGET_BRANCH
TARGET_BRANCH=${TARGET_BRANCH:-$CURRENT_BR}

# 5. Sync and Push
echo "🔄 Fetching and Rebasin' on $TARGET_BRANCH..."

# Final 'add' just in case something changed during the prompts
git add -A 

# If there are still unstaged changes, we stash them temporarily
STASHED=false
if ! git diff --quiet; then
    echo "📦 Stashing temporary changes..."
    git stash --quiet
    STASHED=true
fi

git pull origin "$TARGET_BRANCH" --rebase

if [ "$STASHED" = true ]; then
    echo "📥 Unstashing temporary changes..."
    git stash pop --quiet
fi

git push origin "$TARGET_BRANCH"

echo "--------------------------------------------------"
echo "✅ Successfully synced and pushed to $TARGET_BRANCH!"
