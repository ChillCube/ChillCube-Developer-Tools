#!/usr/bin/env bash
set -e

# --- Chillcube Smart Push ---
echo "🧊 Chillcube Git Sync Initializing..."
echo "--------------------------------------------------"

# Get current status
CURRENT_BR=$(git branch --show-current)
echo "📍 Currently on branch: $CURRENT_BR"

# Preparation: Fix permissions BEFORE we stage for commit
if [ -d "bin" ]; then
    echo "🛡️  Ensuring bin/ files are executable..."
    find bin/ -type f -exec git update-index --chmod=+x {} +
fi

# Stage and Commit
# We use -A to ensure we catch everything (new, modified, deleted)
git add -A

# Only commit if there are actually changes
if ! git diff-index --quiet HEAD --; then
    read -p "📝 Enter commit message: " COMMIT_MSG
    COMMIT_MSG=${COMMIT_MSG:-"update: chillcube tools sync"}
    git commit -m "$COMMIT_MSG"
else
    echo "✨ Nothing new to commit (working tree clean)."
fi

# Branch Selection
echo "--------------------------------------------------"
echo "🌍 Available Remote Branches:"
git fetch --prune --quiet
git branch -r | sed 's/origin\///' | grep -v "HEAD" | sort -u
echo "--------------------------------------------------"

read -p "🎯 Target branch (default: $CURRENT_BR): " TARGET_BRANCH
TARGET_BRANCH=${TARGET_BRANCH:-$CURRENT_BR}

# The "Clean Rebase" Strategy
echo "🔄 Syncing with origin/$TARGET_BRANCH..."

# Check if there are any stray changes (like if a file was modified during the prompt)
HAS_CHANGES=$(git status --porcelain)

if [ -n "$HAS_CHANGES" ]; then
    echo "📦 Stashing temporary changes to allow rebase..."
    git stash push -m "temp-stash-before-rebase"
fi

# Pull with rebase
git pull origin "$TARGET_BRANCH" --rebase

# If we stashed changes, bring them back
if [ -n "$HAS_CHANGES" ]; then
    echo "📥 Applying stashed changes back..."
    git stash pop
fi

# Final Push
git push origin "$TARGET_BRANCH"

echo "--------------------------------------------------"
echo "✅ Successfully synced and pushed to $TARGET_BRANCH!"
