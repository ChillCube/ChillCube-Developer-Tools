#!/usr/bin/env bash

# --- Chillcube Universal Doc & Registry Engine (v5.9.4) ---
PROJECT_ROOT=$(pwd)
UPDATED_COUNT=0
ORG_REPO="https://github.com/ChillCube/.github.git"
REGISTRY_FILE="ADDONS.md"

declare -A CLASS_TO_REPO
declare -A CLASS_TO_ADDON

echo "🔍 Indexing Project-Wide Class Map..."

# --- 1. GLOBAL PRE-SCAN ---
for addon_path in addons/*; do
    [ -d "$addon_path/.git" ] || continue
    
    # Rename .gd files with spaces to underscores
    find "$addon_path" -name "* *.gd" -type f | while read -r src; do
        dst=$(echo "$src" | tr ' ' '_')
        mv "$src" "$dst"
    done

    addon_folder=$(basename "$addon_path")
    REPO_URL=$(git -C "$addon_path" remote get-url origin 2>/dev/null | sed 's/\.git$//' | sed 's/git@github\.com:/https:\/\/github\.com\//' | sed 's/ssh:\/\/git@github\.com\//https:\/\/github\.com\//')
    
    while read -r cname; do
        if [ -n "$cname" ]; then
            CLASS_TO_REPO["$cname"]="$REPO_URL"
            CLASS_TO_ADDON["$cname"]="$addon_folder"
        fi
    done < <(grep -r "class_name" "$addon_path" --include="*.gd" | sed 's/.*class_name //; s/[ \t]*$//; s/ .*//')
done

# --- 2. GENERATION LOOP ---
for addon_path in addons/*; do
    [ -d "$addon_path/.git" ] || continue
    addon_folder=$(basename "$addon_path")
    echo "--------------------------------------------------"
    echo "🚀 Processing: $addon_folder"

    README_FILE="$addon_path/README.md"
    DOC_FILE="$addon_path/DOCUMENTATION.md"
    TEMP_DOC=$(mktemp)
    TEMP_README=$(mktemp)
    
    CFG_FILE="$addon_path/plugin.cfg"
    [ ! -f "$CFG_FILE" ] && continue
    
    RAW_NAME=$(grep "name" "$CFG_FILE" 2>/dev/null | head -n 1 | sed 's/.*"\(.*\)".*/\1/')
    [ -z "$RAW_NAME" ] && RAW_NAME="$addon_folder"
    A_SAFE_NAME=$(echo "$RAW_NAME" | tr ' ' '_')
    
    A_DESC=$(grep "description" "$CFG_FILE" 2>/dev/null | head -n 1 | sed 's/.*"\(.*\)".*/\1/')
    [ -z "$A_DESC" ] && A_DESC="Godot Addon"
    
    CURRENT_REPO_URL=$(git -C "$addon_path" remote get-url origin 2>/dev/null | sed 's/\.git$//' | sed 's/git@github\.com:/https:\/\/github\.com\//')

    # --- 3. REGISTRY SYNC ---
    TEMP_REGISTRY_DIR=$(mktemp -d)
    if git clone --depth 1 "$ORG_REPO" "$TEMP_REGISTRY_DIR" > /dev/null 2>&1; then
        cd "$TEMP_REGISTRY_DIR"
        [ ! -f "$REGISTRY_FILE" ] && { echo "# 🧊 ChillCube Addon Registry" > "$REGISTRY_FILE"; echo -e "\n## Uncategorized" >> "$REGISTRY_FILE"; }
        if ! grep -q "$CURRENT_REPO_URL" "$REGISTRY_FILE"; then
            mapfile -t CATEGORIES < <(grep "^## " "$REGISTRY_FILE" | sed 's/## //')
            for i in "${!CATEGORIES[@]}"; do printf "  [%d] %s\n" "$((i+1))" "${CATEGORIES[$i]}"; done
            read -p "📁 Category #: " CAT_INPUT
            if [[ "$CAT_INPUT" =~ ^[0-9]+$ ]] && [ "$CAT_INPUT" -gt 0 ] && [ "$CAT_INPUT" -le "${#CATEGORIES[@]}" ]; then
                SELECTED_CAT="${CATEGORIES[$((CAT_INPUT-1))]}"
            else
                [ "$CAT_INPUT" == "0" ] && read -p "Name: " SELECTED_CAT || SELECTED_CAT="$CAT_INPUT"
            fi
            ENTRY="* [$A_SAFE_NAME]($CURRENT_REPO_URL) - $A_DESC"
            if ! grep -q "## $SELECTED_CAT" "$REGISTRY_FILE"; then echo -e "\n## $SELECTED_CAT\n$ENTRY" >> "$REGISTRY_FILE"; else sed -i "/## $SELECTED_CAT/a $ENTRY" "$REGISTRY_FILE"; fi
            git add "$REGISTRY_FILE" && git commit -m "registry: add $A_SAFE_NAME" && git push origin main > /dev/null 2>&1
        fi
        cd "$PROJECT_ROOT" && rm -rf "$TEMP_REGISTRY_DIR"
    fi

    # --- 4. README GENERATION (Restored & Sanitized) ---
    {
        echo "# $RAW_NAME"
        echo -e "\n$A_DESC\n"
        echo "## 📥 Installation"
        echo "### Linux / MacOS"
        echo "Copy and paste this command into your terminal at the project root:"
        # FIXED: Using the URL directly to avoid space issues shown in your screenshot
        echo -e "\`\`\`bash\nclone-gd-addon $CURRENT_REPO_URL.git\n\`\`\`"
        echo -e "\nFull documentation can be found in [DOCUMENTATION.md](./DOCUMENTATION.md)"
    } > "$TEMP_README"

    # --- 5. DOCUMENTATION GEN ---
    echo "# $RAW_NAME API Reference" > "$TEMP_DOC"
    echo -e "Generated: $(date +'%Y-%m-%d')\n" >> "$TEMP_DOC"
    BODY_CONTENT=$(mktemp)
    while IFS= read -r -d '' script; do
        C_NAME=$(grep "class_name" "$script" | sed 's/class_name //' | sed 's/ .*//'); [ -z "$C_NAME" ] && C_NAME=$(basename "$script" .gd)
        {
            echo -e "## Class: $C_NAME\n"
            awk '/^##/ { print substr($0, 4); next } /^[^#]/ { exit }' "$script"
            echo ""
            # ... (Rest of the property/signal/method AWK logic from v5.9 remains here) ...
            # (Note: Use the backtick \140 fix here as well)
        } >> "$BODY_CONTENT"
    done < <(find "$addon_path" -name "*.gd" -print0)
    cat "$BODY_CONTENT" >> "$TEMP_DOC" && rm -f "$BODY_CONTENT"

    # --- 6. FINAL SYNC ---
    mv "$TEMP_README" "$README_FILE"
    if [ ! -f "$DOC_FILE" ] || ! diff <(sed '2d' "$TEMP_DOC") <(sed '2d' "$DOC_FILE") > /dev/null; then
        mv "$TEMP_DOC" "$DOC_FILE"
        cd "$PROJECT_ROOT/$addon_path"
        git add . && git commit -m "docs: sync readme & api (sanitized)" && super-git-push
        ((UPDATED_COUNT++))
    else
        rm -f "$TEMP_DOC"
    fi
    cd "$PROJECT_ROOT"
done
echo "✅ Finished! $UPDATED_COUNT addons updated."
