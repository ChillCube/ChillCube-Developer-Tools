#!/usr/bin/env bash

# --- Chillcube Bulk Addon Pusher & Doc Generator ---

VENV_PATH="/tmp/chillcube_docs_env"
if ! command -v godocs &> /dev/null; then
    if [ ! -d "$VENV_PATH" ]; then
        python3 -m venv "$VENV_PATH"
        "$VENV_PATH/bin/pip" install godocs godocs-jinja --quiet
    fi
    export PATH="$VENV_PATH/bin:$PATH"
fi

PROJECT_ROOT=$(pwd)

for addon_path in addons/*; do
    [ -d "$addon_path/.git" ] || continue
    addon_name=$(basename "$addon_path")
    
    echo "--------------------------------------------------"
    echo "🚀 Addon: $addon_name"

    find "$addon_path" -name "*.gd" -exec sed -i 's/    /\t/g' {} +

    TEMP_XML="$PROJECT_ROOT/temp_xml_$addon_name"
    TEMP_OUT="$PROJECT_ROOT/docs_out_$addon_name"
    mkdir -p "$TEMP_XML" "$TEMP_OUT"

    godot --headless --doctool "$TEMP_XML" --no-docbase --gdscript-docs "res://addons/$addon_name"
    
    if [ "$(ls -A "$TEMP_XML" 2>/dev/null)" ]; then
        echo "📝 Reconstructing Documentation..."
        godocs construct jinja --format md "$TEMP_XML" "$TEMP_OUT"
        
        DOC_FILE="$PROJECT_ROOT/$addon_path/DOCUMENTATION.md"
        echo "# $addon_name API Reference" > "$DOC_FILE"
        echo -e "Generated on: $(date)\n\n---\n" >> "$DOC_FILE"

        for f in "$TEMP_OUT"/*.md; do
            [ -e "$f" ] || continue
            [[ $(basename "$f") == "index.md" ]] && continue
            
            # Add class separator if file isn't empty
            [ -s "$DOC_FILE" ] && [ "$(wc -l < "$DOC_FILE")" -gt 6 ] && echo -e "\n\n---\n" >> "$DOC_FILE"

            cat "$f" | sed -E \
                -e 's/:ref:`[^<]* <([^>]*)>`/\1/g' \
                -e 's/\\//g' \
                -e 's/``//g' \
                -e '/^Inherits:/d' \
                -e '/^\*\*Inherits:\*\*/d' \
                -e '/[A-Za-z ]+ Index/d' \
                -e '/^\.\. /d' \
                -e '/^[=-]+$/d' \
                -e '/Descriptions$/d' \
                -e '/^Index$/d' | \
            awk '
                BEGIN { 
                    header_done = 0; getting_desc = 0;
                    prop_text = ""; method_text = ""; signal_text = "";
                    current_item = "";
                }
                
                # Signals
                /^[a-zA-Z0-9_]+\(.*\)$/ && !/ / {
                    current_item = "### " $0 "\n**Event:** Signal\n\n"
                    target = "signal"
                    getting_desc = 1; next
                }

                # Properties
                /^[a-zA-Z0-9_]+ [a-zA-Z0-9_]+([ ]?=[ ]?.*)?$/ {
                    split($0, parts, "=")
                    split(parts[1], head, " ")
                    type = head[1]; name = head[2]
                    
                    current_item = "### " name "\n**Type:** " type "\n"
                    if ($0 ~ /=/) {
                        def = parts[2]; sub(/^[ ]+/, "", def); sub(/[ ]+$/, "", def)
                        current_item = current_item "**Default:** " def "\n"
                    }
                    current_item = current_item "\n"
                    target = "prop"
                    getting_desc = 1; next
                }

                # Methods
                /^[a-zA-Z0-9_]+ [a-zA-Z0-9_]+\(.*\)$/ {
                    split($0, head, " ")
                    type = head[1]
                    sig = $0; sub(/^[a-zA-Z0-9_]+ /, "", sig)
                    
                    current_item = "### " sig "\n**Returns:** " type "\n\n"
                    target = "method"
                    getting_desc = 1; next
                }

                # Capturing description lines into the current item
                getting_desc {
                    if ($0 ~ /^#/ || $0 ~ /^`/) { 
                        getting_desc = 0 
                    } else if (NF > 0) {
                        current_item = current_item $0 "\n\n"
                        if (target == "prop") prop_text = prop_text current_item;
                        if (target == "method") method_text = method_text current_item;
                        if (target == "signal") signal_text = signal_text current_item;
                        current_item = ""; # Reset so we dont double-append
                        next
                    }
                }

                # Main Class Header & Description
                {
                    if ($0 ~ /header-rows/ || $0 ~ /\* -/ || $0 ~ /^[ ]+- /) next
                    if (!header_done && $0 !~ /^#/ && length($0) > 2) {
                        print "## " $0 "\n"
                        header_done = 1
                    } else if (!getting_desc && header_done) {
                        print $0
                    }
                }

                END {
                    if (signal_text != "") print "## Signals\n" signal_text
                    if (prop_text != "") print "## Properties\n" prop_text
                    if (method_text != "") print "## Methods\n" method_text
                }
            ' >> "$DOC_FILE"
        done
        sed -i '/^$/N;/^\n$/D' "$DOC_FILE"
    fi

    # 4. GIT SYNC
    cd "$PROJECT_ROOT/$addon_path"
    if [ -f "DOCUMENTATION.md" ]; then
        git add DOCUMENTATION.md
        if ! git diff-index --quiet HEAD; then
            git commit -m "docs: auto-generate documentation"
            super-git-push || "$PROJECT_ROOT/bin/super-git-push"
        fi
    fi

    cd "$PROJECT_ROOT"
    rm -rf "$TEMP_XML" "$TEMP_OUT"
    echo "✅ Finished $addon_name"
done
