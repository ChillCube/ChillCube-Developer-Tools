#!/usr/bin/env bash

# --- Chillcube Bulk Addon Pusher & Doc Generator ---

TEMPLATE_URL="https://raw.githubusercontent.com/ChillCube/ChillCube-Developer-Tools/main/templates/README_GODOT_ADDON_TEMPLATE.md"
VENV_PATH="/tmp/chillcube_docs_env"

if ! command -v godocs &> /dev/null; then
    if [ ! -d "$VENV_PATH" ]; then
        python3 -m venv "$VENV_PATH"
        "$VENV_PATH/bin/pip" install godocs godocs-jinja --quiet
    fi
    export PATH="$VENV_PATH/bin:$PATH"
fi

PROJECT_ROOT=$(pwd)

for addon_path in addons/*; do
    [ -d "$addon_path/.git" ] || continue
    addon_name_folder=$(basename "$addon_path")
    
    echo "--------------------------------------------------"
    echo "🚀 Processing Addon: $addon_name_folder"

    # 1. FIX INDENTATION
    find "$addon_path" -name "*.gd" -exec sed -i 's/    /\t/g' {} +

    # 2. REGENERATE README FROM REMOTE TEMPLATE
    if [ -f "$addon_path/plugin.cfg" ]; then
        echo "♻️  Regenerating README from master template..."
        
        # Extract metadata from plugin.cfg
        A_NAME=$(grep -E "^name[[:space:]]*=" "$addon_path/plugin.cfg" | sed 's/.*=[[:space:]]*"//;s/".*//')
        A_DESC=$(grep -E "^description[[:space:]]*=" "$addon_path/plugin.cfg" | sed 's/.*=[[:space:]]*"//;s/".*//')
        A_AUTH=$(grep -E "^author[[:space:]]*=" "$addon_path/plugin.cfg" | sed 's/.*=[[:space:]]*"//;s/".*//')
        A_YEAR=$(date +%Y)

        # Download fresh template to a temporary file
        curl -sSL "$TEMPLATE_URL" -o "$addon_path/README.md.tmp"
        
        if [ -s "$addon_path/README.md.tmp" ]; then
            # Apply metadata to the fresh template
            sed -i "s/{{NAME}}/$A_NAME/g" "$addon_path/README.md.tmp"
            sed -i "s/{{DESC}}/$A_DESC/g" "$addon_path/README.md.tmp"
            sed -i "s/{{AUTHOR}}/$A_AUTH/g" "$addon_path/README.md.tmp"
            sed -i "s/{{YEAR}}/$A_YEAR/g" "$addon_path/README.md.tmp"
            
            # Force overwrite the old README
            mv "$addon_path/README.md.tmp" "$addon_path/README.md"
            echo "✅ README regenerated for $A_NAME"
        else
            rm -f "$addon_path/README.md.tmp"
            echo "❌ Error: Could not download template. Keeping existing README."
        fi
    fi

    # 3. GENERATE API DOCUMENTATION
    TEMP_XML="$PROJECT_ROOT/temp_xml_$addon_name_folder"
    TEMP_OUT="$PROJECT_ROOT/docs_out_$addon_name_folder"
    mkdir -p "$TEMP_XML" "$TEMP_OUT"

    godot --headless --doctool "$TEMP_XML" --no-docbase --gdscript-docs "res://addons/$addon_name_folder"
    
    if [ "$(ls -A "$TEMP_XML" 2>/dev/null)" ]; then
        echo "📝 Reconstructing Documentation..."
        godocs construct jinja --format md "$TEMP_XML" "$TEMP_OUT"
        
        DOC_FILE="$PROJECT_ROOT/$addon_path/DOCUMENTATION.md"
        DISPLAY_NAME=${A_NAME:-$addon_name_folder}
        
        echo "# $DISPLAY_NAME API Reference" > "$DOC_FILE"
        echo -e "Generated on: $(date)\n\n---\n" >> "$DOC_FILE"

        for f in "$TEMP_OUT"/*.md; do
            [ -e "$f" ] || continue
            [[ $(basename "$f") == "index.md" ]] && continue
            
            [ -s "$DOC_FILE" ] && [ "$(wc -l < "$DOC_FILE")" -gt 8 ] && echo -e "\n\n---\n" >> "$DOC_FILE"

            cat "$f" | sed -E \
                -e 's/:ref:`[^<]* <([^>]*)>`/\1/g' \
                -e 's/\\//g' \
                -e 's/``//g' \
                -e '/^Inherits:/d' \
                -e '/^\*\*Inherits:\*\*/d' \
                -e '/[A-Za-z ]+ Index/d' \
                -e '/^\.\. /d' \
                -e '/^[=-]+$/d' \
                -e '/Descriptions$/d' \
                -e '/^Index$/d' | \
            awk '
                BEGIN { 
                    header_done = 0; getting_desc = 0;
                    prop_text = ""; method_text = ""; signal_text = "";
                    current_item = ""; target = "";
                }
                /^[a-zA-Z0-9_]+\(.*\)$/ && !/ / {
                    current_item = "### " $0 "\n**Event:** Signal\n\n"
                    target = "signal"; getting_desc = 1; next
                }
                /^[a-zA-Z0-9_]+ [a-zA-Z0-9_]+([ ]?=[ ]?.*)?$/ {
                    split($0, parts, "=")
                    split(parts[1], head, " ")
                    current_item = "### " head[2] "\n**Type:** " head[1] "\n"
                    if ($0 ~ /=/) {
                        def = parts[2]; sub(/^[ ]+/, "", def); sub(/[ ]+$/, "", def)
                        current_item = current_item "**Default:** " def "\n"
                    }
                    current_item = current_item "\n"
                    target = "prop"; getting_desc = 1; next
                }
                /^[a-zA-Z0-9_]+ [a-zA-Z0-9_]+\(.*\)$/ {
                    split($0, head, " ")
                    sig = $0; sub(/^[a-zA-Z0-9_]+ /, "", sig)
                    current_item = "### " sig "\n**Returns:** " head[1] "\n\n"
                    target = "method"; getting_desc = 1; next
                }
                getting_desc {
                    if ($0 ~ /^#/ || $0 ~ /^`/) { getting_desc = 0 }
                    else if (NF > 0) {
                        current_item = current_item $0 "\n\n"
                        if (target == "prop") prop_text = prop_text current_item;
                        else if (target == "method") method_text = method_text current_item;
                        else if (target == "signal") signal_text = signal_text current_item;
                        current_item = ""; next
                    }
                }
                {
                    if ($0 ~ /header-rows/ || $0 ~ /\* -/ || $0 ~ /^[ ]+- /) next
                    if (!header_done && $0 !~ /^#/ && length($0) > 2) {
                        print "## " $0 "\n"; header_done = 1
                    } else if (!getting_desc && header_done) {
                        print $0
                    }
                }
                END {
                    if (signal_text != "") print "\n## Signals\n" signal_text
                    if (prop_text != "") print "\n## Properties\n" prop_text
                    if (method_text != "") print "\n## Methods\n" method_text
                }
            ' >> "$DOC_FILE"
        done
        sed -i '/^$/N;/^\n$/D' "$DOC_FILE"
    fi

    # 4. INTERACTIVE GIT SYNC
    cd "$PROJECT_ROOT/$addon_path"
    git add DOCUMENTATION.md README.md
    
    if ! git diff-index --quiet HEAD; then
        echo -e "\n💬 Enter commit message for [$addon_name_folder]:"
        read -p "> " user_message
        
        if [ -z "$user_message" ]; then
            user_message="sync: regenerate docs and readme template"
        fi

        git commit -m "docs($addon_name_folder): $user_message"
        
        echo "📤 Pushing changes..."
        super-git-push || "$PROJECT_ROOT/bin/super-git-push"
    else
        echo "ℹ️  No changes detected for $addon_name_folder."
    fi

    cd "$PROJECT_ROOT"
    rm -rf "$TEMP_XML" "$TEMP_OUT"
    echo "✅ Finished $addon_name_folder"
done
