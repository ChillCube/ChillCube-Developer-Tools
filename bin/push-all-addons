#!/usr/bin/env bash

# --- Chillcube Bulk Addon Pusher & Doc Generator ---
TEMPLATE_URL="https://raw.githubusercontent.com/ChillCube/ChillCube-Developer-Tools/main/templates/README_GODOT_ADDON_TEMPLATE.md"
VENV_PATH="/tmp/chillcube_docs_env"

# Ensure godocs is available for API generation (Optional: using built-in awk for tables now)
if ! command -v godocs &> /dev/null; then
    if [ ! -d "$VENV_PATH" ]; then
        python3 -m venv "$VENV_PATH"
        "$VENV_PATH/bin/pip" install godocs godocs-jinja --quiet 2>/dev/null || echo "Python venv setup skipped."
    fi
    export PATH="$VENV_PATH/bin:$PATH"
fi

PROJECT_ROOT=$(pwd)

# Ensure we are in a Godot project
if [ ! -d "addons" ]; then
    echo "❌ Error: No addons/ folder found in $(pwd)"
    exit 1
fi

for addon_path in addons/*; do
    [ -d "$addon_path/.git" ] || continue
    addon_folder=$(basename "$addon_path")
    
    echo "--------------------------------------------------"
    echo "🚀 Processing Addon: $addon_folder"

    # --- 0. DEPENDENCY RESOLUTION ---
    DEP_FILE="$addon_path/DEPENDENCIES.txt"
    if [ -f "$DEP_FILE" ]; then
        echo "🔗 Checking dependencies for $addon_folder..."
        while read -r dep_url || [ -n "$dep_url" ]; do
            [[ -z "$dep_url" || "$dep_url" =~ ^# ]] && continue
            
            dep_name=$(basename "$dep_url" .git)
            dep_target="addons/$dep_name"
            
            if [ ! -d "$dep_target" ]; then
                echo "  📥 Cloning missing dependency: $dep_name..."
                git clone --depth 1 "$dep_url" "$dep_target"
            else
                echo "  ⏭️  Dependency $dep_name already present."
            fi
        done < "$DEP_FILE"
    fi

    # --- 1. SCRAPE METADATA FROM PLUGIN.CFG ---
    CFG_FILE="$addon_path/plugin.cfg"
    if [ -f "$CFG_FILE" ]; then
        A_NAME=$(grep "name" "$CFG_FILE" | head -n 1 | sed 's/.*"\(.*\)".*/\1/')
        A_DESC=$(grep "description" "$CFG_FILE" | head -n 1 | sed 's/.*"\(.*\)".*/\1/')
        A_AUTH=$(grep "author" "$CFG_FILE" | head -n 1 | sed 's/.*"\(.*\)".*/\1/')
        A_MAIN_SCRIPT=$(grep "script" "$CFG_FILE" | head -n 1 | sed 's/.*"\(.*\)".*/\1/')
        A_YEAR=$(date +%Y)
    else
        A_NAME="$addon_folder"
        A_DESC="A Godot Addon"
        A_AUTH="ChillCube"
        A_YEAR=$(date +%Y)
        A_MAIN_SCRIPT=""
    fi

    # --- 2. REGENERATE README ---
    echo "📥 Regenerating README from template..."
    curl -sSL "$TEMPLATE_URL" -o "$addon_path/README.md"
    sed -i "s@{{NAME}}@$A_NAME@g" "$addon_path/README.md"
    sed -i "s@{{DESC}}@$A_DESC@g" "$addon_path/README.md"
    sed -i "s@{{AUTHOR}}@$A_AUTH@g" "$addon_path/README.md"
    sed -i "s@{{YEAR}}@$A_YEAR@g" "$addon_path/README.md"

    # --- 3. GENERATE TABLE-BASED API DOCUMENTATION ---
    DOC_FILE="$addon_path/DOCUMENTATION.md"
    echo "📖 Generating table-based documentation for $A_NAME..."
    
    echo "# $A_NAME API Reference" > "$DOC_FILE"
    echo "Generated on: $(date)" >> "$DOC_FILE"
    echo -e "\n$A_DESC" >> "$DOC_FILE"
    echo -e "\n---\n" >> "$DOC_FILE"

    # Find the primary script. If plugin.cfg doesn't point to one, look for any .gd file
    TARGET_SCRIPT="$addon_path/$A_MAIN_SCRIPT"
    if [ ! -f "$TARGET_SCRIPT" ]; then
        TARGET_SCRIPT=$(find "$addon_path" -name "*.gd" | head -n 1)
    fi

    if [ -f "$TARGET_SCRIPT" ]; then
        echo "📄 Parsing script: $TARGET_SCRIPT"
        
        # TABLE: PROPERTIES
        echo "## Properties" >> "$DOC_FILE"
        echo "| Property | Type | Default | Description |" >> "$DOC_FILE"
        echo "| :--- | :--- | :--- | :--- |" >> "$DOC_FILE"
        awk '
            /^#/ { last_comment = last_comment " " substr($0, 3) }
            /^@export|^var / {
                if ($0 ~ /^var / && last_comment == "") { next } # Skip local vars without comments
                type = "Variant"; name = ""; default_val = "-";
                split($0, a, "var "); split(a[2], b, "[:= ]"); name = b[1];
                if ($0 ~ /:/) { split($0, c, ":"); split(c[2], d, "[:= ]"); type = d[1] }
                if ($0 ~ /=/) { split($0, e, "="); default_val = e[2]; gsub(/^[ \t]+|[ \t]+$/, "", default_val) }
                gsub(/^ /, "", last_comment); if (last_comment == "") last_comment = "No description provided.";
                printf("| **%s** | `%s` | `%s` | %s |\n", name, type, default_val, last_comment);
                last_comment = ""
            }
            !/^#/ && !/^@export/ && !/^var / { last_comment = "" }
        ' "$TARGET_SCRIPT" >> "$DOC_FILE"

        # TABLE: METHODS
        echo -e "\n## Methods" >> "$DOC_FILE"
        echo "| Method | Returns | Description |" >> "$DOC_FILE"
        echo "| :--- | :--- | :--- |" >> "$DOC_FILE"
        awk '
            /^#/ { last_comment = last_comment " " substr($0, 3) }
            /^func / {
                split($0, a, "func "); split(a[2], b, "("); name = b[1]
                ret = "void"
                if ($0 ~ /->/) { split($0, c, "->"); split(c[2], d, ":"); ret = d[1]; gsub(/ /, "", ret) }
                gsub(/^ /, "", last_comment); if (last_comment == "") last_comment = "No description provided.";
                printf("| **%s()** | `%s` | %s |\n", name, ret, last_comment);
                last_comment = ""
            }
            !/^#/ && !/^func / { last_comment = "" }
        ' "$TARGET_SCRIPT" >> "$DOC_FILE"
        
        # TABLE: SIGNALS
        echo -e "\n## Signals" >> "$DOC_FILE"
        echo "| Signal | Description |" >> "$DOC_FILE"
        echo "| :--- | :--- |" >> "$DOC_FILE"
        awk '
            /^#/ { last_comment = last_comment " " substr($0, 3) }
            /^signal / {
                split($0, a, "signal "); name = a[2];
                gsub(/^ /, "", last_comment); if (last_comment == "") last_comment = "No description provided.";
                printf("| **%s** | %s |\n", name, last_comment);
                last_comment = ""
            }
            !/^#/ && !/^signal / { last_comment = "" }
        ' "$TARGET_SCRIPT" >> "$DOC_FILE"
    fi

    # --- 4. INTERACTIVE GIT SYNC ---
    cd "$PROJECT_ROOT/$addon_path"
    git add README.md DOCUMENTATION.md
    
    if ! git diff --cached --quiet; then
        echo -e "\n💬 Changes ready for [$addon_folder]."
        read -p "Enter commit message (empty for default): " user_msg
        user_msg=${user_msg:-"sync: update documentation and readme template"}
        
        git commit -m "docs($addon_folder): $user_msg"
        
        echo "📤 Pushing to GitHub..."
        # Fallback sequence for the push command
        if command -v super-git-push &> /dev/null; then
            super-git-push
        elif [ -f "$PROJECT_ROOT/bin/super-git-push" ]; then
            "$PROJECT_ROOT/bin/super-git-push"
        else
            git push origin main
        fi
    else
        echo "ℹ️ No changes detected for $addon_folder."
    fi

    cd "$PROJECT_ROOT"
    echo "✅ Finished $addon_folder"
done
