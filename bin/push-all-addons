#!/usr/bin/env bash

# --- Chillcube Bulk Addon Pusher & Doc Generator (Universal Version) ---

# 1. SETUP TEMPORARY ENVIRONMENT
VENV_PATH="/tmp/chillcube_docs_env"
if ! command -v godocs &> /dev/null; then
    if [ ! -d "$VENV_PATH" ]; then
        python3 -m venv "$VENV_PATH"
        "$VENV_PATH/bin/pip" install godocs godocs-jinja --quiet
    fi
    export PATH="$VENV_PATH/bin:$PATH"
fi

PROJECT_ROOT=$(pwd)

for addon_path in addons/*; do
    [ -d "$addon_path/.git" ] || continue
    addon_name=$(basename "$addon_path")
    
    echo "--------------------------------------------------"
    echo "🚀 Addon: $addon_name"

    # Fix indentation: Godot 4 parser requires Tabs, not Spaces
    find "$addon_path" -name "*.gd" -exec sed -i 's/    /\t/g' {} +

    TEMP_XML="$PROJECT_ROOT/temp_xml_$addon_name"
    TEMP_OUT="$PROJECT_ROOT/docs_out_$addon_name"
    mkdir -p "$TEMP_XML" "$TEMP_OUT"

    # Extracting XML from Godot
    godot --headless --doctool "$TEMP_XML" --no-docbase --gdscript-docs "res://addons/$addon_name"
    
    if [ "$(ls -A "$TEMP_XML" 2>/dev/null)" ]; then
        echo "📝 Reconstructing Documentation..."
        godocs construct jinja --format md "$TEMP_XML" "$TEMP_OUT"
        
        DOC_FILE="$PROJECT_ROOT/$addon_path/DOCUMENTATION.md"
        echo "# $addon_name API Reference" > "$DOC_FILE"
        echo -e "Generated on: $(date)\n" >> "$DOC_FILE"

        for f in "$TEMP_OUT"/*.md; do
            [ -e "$f" ] || continue
            if [[ $(basename "$f") != "index.md" ]]; then
                
                # Use POSIX-compliant AWK logic for Nix/Linux compatibility
                cat "$f" | awk -v addon="$addon_name" '
                    BEGIN { 
                        section = "none"; getting_desc = 0;
                        class_desc = ""; body = "";
                    }

                    # Clean global artifacts
                    {
                        gsub(/:ref:`[^<]* <([^>]*)>`/, "`\\1`")
                        gsub(/\\/, "")
                    }

                    # Skip RST/Table leftovers
                    /^\.\. / || /^\s+:header-rows:/ || /^\s+\* -/ || /^\s+- / || /^Inherits:/ || /^[=-]+$/ { next }

                    # Section Headers
                    /Property Descriptions/ { section = "props"; next }
                    /Method Descriptions/ { section = "methods"; next }
                    /Signal Descriptions/ { section = "signals"; next }

                    # 1. Main Description Capture
                    section == "none" && !/^#/ && NF > 0 && $0 !~ /Index/ {
                        if ($0 != addon && $0 != "Class Reference") {
                            class_desc = class_desc $0 "\n\n"
                        }
                    }

                    # 2. Properties (`Type` name = `Default`)
                    section == "props" && /^`[^`]+` [^` ]+/ {
                        split($0, parts, "`")
                        type = parts[2]
                        # Handle the rest of the line manually to avoid regex group failures
                        rest = parts[3]
                        if (rest ~ /=/) {
                            # Extract name before =
                            name_part = rest; sub(/ =.*/, "", name_part); gsub(/ /, "", name_part)
                            # Default value is in the next backtick block
                            default_val = parts[4]
                        } else {
                            name_part = rest; gsub(/ /, "", name_part)
                            default_val = ""
                        }

                        body = body "### " name_part "\n**Type:** `" type "`\n"
                        if (default_val != "") body = body "**Default:** `" default_val "`\n"
                        body = body "\n"
                        getting_desc = 1; next
                    }

                    # 3. Methods (`Type` name(...))
                    section == "methods" && /^`[^`]+` [^` ]+\(.*\)$/ {
                        split($0, parts, "`")
                        type = parts[2]
                        sig = parts[3]; sub(/^ /, "", sig)

                        body = body "### " sig "\n**Returns:** `" type "`\n\n"
                        getting_desc = 1; next
                    }

                    # 4. Signals
                    section == "signals" && /^[a-zA-Z0-9_]+\(.*\)$/ {
                        body = body "### " $0 "\n**Event:** Signal\n\n"
                        getting_desc = 1; next
                    }

                    # 5. Description Block Logic
                    getting_desc {
                        if ($0 ~ /^#/ || $0 ~ /^`/) { getting_desc = 0 }
                        else if (NF > 0) {
                            body = body $0 "\n\n"
                        }
                    }

                    END {
                        # Scrub remaining table artifacts from description
                        gsub(/Name\n\nDefault value\n\n/, "", class_desc)
                        gsub(/Return type\n\nSignature\n\n/, "", class_desc)
                        
                        if (class_desc != "") {
                            print "## Description\n" class_desc "\n---\n"
                        }
                        print body
                    }
                ' >> "$DOC_FILE"
            fi
        done
    fi

    # 3. SYNC TO GIT
    cd "$PROJECT_ROOT/$addon_path"
    if [ -f "DOCUMENTATION.md" ]; then
        git add DOCUMENTATION.md
        if ! git diff-index --quiet HEAD; then
            echo "💾 Committing documentation..."
            git commit -m "docs: auto-generate documentation"
        fi
    fi

    echo "📤 Running push..."
    if command -v super-git-push >/dev/null 2>&1; then
        super-git-push
    else
        "$PROJECT_ROOT/bin/super-git-push"
    fi

    cd "$PROJECT_ROOT"
    rm -rf "$TEMP_XML" "$TEMP_OUT"
    echo "✅ Finished $addon_name"
done
