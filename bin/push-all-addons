#!/usr/bin/env bash

# --- Chillcube Universal Doc, Deep-Dependency & Validation Engine ---
TEMPLATE_URL="https://raw.githubusercontent.com/ChillCube/ChillCube-Developer-Tools/main/templates/README_GODOT_ADDON_TEMPLATE.md"
PROJECT_ROOT=$(pwd)

declare -A CLASS_TO_REPO
declare -A CLASS_TO_ADDON
ALL_CUSTOM_CLASSES=""

echo "🔍 Indexing Project-Wide Class Map..."

# --- 1. GLOBAL PRE-SCAN ---
for addon_path in addons/*; do
    [ -d "$addon_path/.git" ] || continue
    addon_folder=$(basename "$addon_path")
    
    REPO_URL=$(git -C "$addon_path" remote get-url origin 2>/dev/null | \
               sed 's/\.git$//' | sed 's/git@github\.com:/https:\/\/github\.com\//' | \
               sed 's/ssh:\/\/git@github\.com\//https:\/\/github\.com\//')
    
    while read -r cname; do
        if [ -n "$cname" ]; then
            CLASS_TO_REPO["$cname"]="$REPO_URL"
            CLASS_TO_ADDON["$cname"]="$addon_folder"
            ALL_CUSTOM_CLASSES+="$cname "
        fi
    done < <(grep -r "class_name" "$addon_path" --include="*.gd" | sed 's/.*class_name //; s/[ \t]*$//; s/ .*//')
done

# --- 2. GENERATION LOOP ---
for addon_path in addons/*; do
    [ -d "$addon_path/.git" ] || continue
    addon_folder=$(basename "$addon_path")
    echo "--------------------------------------------------"
    echo "🚀 Processing: $addon_folder"

    DOC_FILE="$addon_path/DOCUMENTATION.md"
    DEP_FILE="$addon_path/DEPENDENCIES.txt"
    TEMP_DOC=$(mktemp)
    
    declare -A LOCAL_DEPS

    # Plugin Metadata
    CFG_FILE="$addon_path/plugin.cfg"
    if [ -f "$CFG_FILE" ]; then
        A_NAME=$(grep "name" "$CFG_FILE" | head -n 1 | sed 's/.*"\(.*\)".*/\1/')
        A_DESC=$(grep "description" "$CFG_FILE" | head -n 1 | sed 's/.*"\(.*\)".*/\1/')
    else
        A_NAME="$addon_folder"; A_DESC="Godot Addon"
    fi
    
    echo "# $A_NAME API Reference" > "$TEMP_DOC"
    echo -e "Generated on: $(date +'%Y-%m-%d')\n\n$A_DESC\n" >> "$TEMP_DOC"

    # --- 3. SCRIPT PROCESSING & DEEP DEPENDENCY SCAN ---
    BODY_CONTENT=$(mktemp)
    mapfile -t SCRIPTS < <(find "$addon_path" -name "*.gd")

    for script in "${SCRIPTS[@]}"; do
        # DEEP SCAN: Find every word starting with Uppercase that matches a known class
        # This catches: extends, type-hints, static calls, and even 'is MyClass' checks
        POTENTIAL_CLASSES=$(grep -oE '\b[A-Z][a-zA-Z0-9_]+\b' "$script" | sort -u)
        
        for check_class in $POTENTIAL_CLASSES; do
            DEP_ADDON="${CLASS_TO_ADDON[$check_class]}"
            
            if [ -n "$DEP_ADDON" ] && [ "$DEP_ADDON" != "$addon_folder" ]; then
                LOCAL_DEPS["$DEP_ADDON"]="${CLASS_TO_REPO[$check_class]}"
            fi
            
            # Warning logic for unknown classes (ignoring common built-ins)
            if [[ ! " $ALL_CUSTOM_CLASSES " =~ " $check_class " ]]; then
                if [[ ! "$check_class" =~ ^(Node|Sprite|Vector|String|int|float|bool|Array|Dictionary|Resource|Object|Input|SceneTree|Engine|JSON|OS|Time|Color|Rect2|Callable|Signal) ]]; then
                     # Only warn if it's not a standard Godot built-in
                     echo "⚠️  WARNING: Unknown class '$check_class' found in '$script'"
                fi
            fi
        done

        # --- CLASS DOC GENERATION ---
        C_NAME=$(grep "class_name" "$script" | sed 's/class_name //' | sed 's/ .*//')
        [ -z "$C_NAME" ] && C_NAME=$(basename "$script" .gd)
        
        RAW_EXT=$(grep "^extends " "$script" | sed 's/extends //' | sed 's/ .*//')
        [ -z "$RAW_EXT" ] && RAW_EXT="Object"
        if [[ -n "${CLASS_TO_REPO[$RAW_EXT]}" ]]; then
            [[ "${CLASS_TO_ADDON[$RAW_EXT]}" == "$addon_folder" ]] && \
                L="[\`$RAW_EXT\`](#class-$RAW_EXT)" || \
                L="[\`$RAW_EXT\`](${CLASS_TO_REPO[$RAW_EXT]}/blob/main/DOCUMENTATION.md#class-$RAW_EXT)"
        elif [[ "$RAW_EXT" =~ ^[A-Z] ]]; then L="[\`$RAW_EXT\`](https://docs.godotengine.org/en/stable/classes/class_${RAW_EXT,,}.html)"; else L="\`$RAW_EXT\`"; fi

        {
            echo -e "## Class: $C_NAME"
            echo -e "**Inherits:** $L\n"
            awk '/^##/ { print substr($0, 4); next } /^[^#]/ { exit }' "$script"
            echo ""
            
            # AWK Properties (Fixed for multi-line/dictionary/array support)
            PD=$(awk 'BEGIN{r=0;b="";d="";n="";t=""} /^[ \t]*(@export.*)?var/ && /##/ { r=1; split($0,p,"##"); d=p[2]; gsub(/^[ \t]+|[ \t]+$/,"",d); c=p[1]; split(c,np,"var "); split(np[2],b2,/[ :={]/); n=b2[1]; t="Variant"; if(c~/:[ \t]*[a-zA-Z0-9_]+/){match(c,/:[ \t]*[a-zA-Z0-9_]+/); t=substr(c,RSTART+1,RLENGTH-1); gsub(/[ \t]+/,"",t)} b=c; if(c!~"{" && c!~"[") f() } r==1 && $0!~"var" { nl=$0; if(nl~"##"){split(nl,tmp,"##"); nl=tmp[1]} b=b " " nl } r==1 && ($0~"}" || $0~"]") { f() } function f(){ dv="-"; if(b~"="){ ei=index(b,"="); ae=substr(b,ei+1); bi=(ae~"{")?index(ae,"{"):(ae~"["?index(ae,"["):0); dv=(bi>0)?substr(ae,bi):ae } gsub(/[ \t]+/," ",dv); sub(/;[ \t]*$/, "", dv); gsub(/^[ \t]+|[ \t]+$/, "", dv); if(n!="") printf("| **%s** | `%s` | `%s` | %s |\n",n,t,dv,d); r=0; b=""; n="" }' "$script")
            [ -n "$PD" ] && echo -e "### Properties\n| Property | Type | Default | Description |\n| :--- | :--- | :--- | :--- |\n$PD\n"
            
            # Signals & Methods...
            SD=$(awk '/signal .*##/ { line=$0; split(line,p,"##"); d=p[2]; gsub(/^[ \t]+|[ \t]+$/,"",d); code=p[1]; split(code,a,"signal "); split(a[2],b,/[ (]/); n=b[1]; printf("| **%s** | %s |\n",n,d) }' "$script")
            [ -n "$SD" ] && echo -e "### Signals\n| Signal | Description |\n| :--- | :--- |\n$SD\n"
            MD=$(awk '/func .*##/ { line=$0; split(line,p,"##"); d=p[2]; gsub(/^[ \t]+|[ \t]+$/,"",d); code=p[1]; split(code,a,"func "); split(a[2],b, "("); n=b[1]; if(n=="" || n~"^_") next; ret="void"; if(code~"->") { split(code, c, "->"); split(c[2], dr, ":"); ret=dr[1]; gsub(/[ \t]+/,"",ret) } printf("| **%s()** | `%s` | %s |\n", n, ret, d) }' "$script")
            [ -n "$MD" ] && echo -e "### Methods\n| Method | Returns | Description |\n| :--- | :--- | :--- |\n$MD\n"
            echo -e "---\n"
        } >> "$BODY_CONTENT"
    done

    # --- 4. ASSEMBLE DEPENDENCIES ---
    if [ ${#LOCAL_DEPS[@]} -gt 0 ]; then
        echo -e "### 📦 Dependencies" >> "$TEMP_DOC"
        echo "| Addon | Repository |" >> "$TEMP_DOC"
        echo "| :--- | :--- |" >> "$TEMP_DOC"
        > "$DEP_FILE"
        IFS=$'\n' sorted_deps=($(sort <<<"${!LOCAL_DEPS[*]}"))
        unset IFS
        for dep in "${sorted_deps[@]}"; do
            echo "| $dep | [Link](${LOCAL_DEPS[$dep]}) |" >> "$TEMP_DOC"
            echo "${LOCAL_DEPS[$dep]}" >> "$DEP_FILE"
        done
        echo -e "\n---\n" >> "$TEMP_DOC"
    fi

    cat "$BODY_CONTENT" >> "$TEMP_DOC"
    rm "$BODY_CONTENT"

    # --- 5. SYNC ---
    if [ ! -f "$DOC_FILE" ] || ! diff <(sed '2d' "$TEMP_DOC") <(sed '2d' "$DOC_FILE") > /dev/null; then
        mv "$TEMP_DOC" "$DOC_FILE"
        cd "$PROJECT_ROOT/$addon_path"
        git add .
        git commit -m "docs: deep dependency scan and documentation update"
        super-git-push
    else
        rm "$TEMP_DOC"
    fi
    cd "$PROJECT_ROOT"
done
