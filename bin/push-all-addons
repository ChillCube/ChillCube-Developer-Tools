#!/usr/bin/env bash

# --- Chillcube Universal Doc & Registry Engine (v5.0) ---
PROJECT_ROOT=$(pwd)
UPDATED_COUNT=0
MANUAL_MARKER="# --- Manual Dependencies (Do Not Delete) ---"
ORG_REPO="https://github.com/ChillCube/.github.git"
REGISTRY_FILE="ADDONS.md"
REGISTRY_TEMPLATE="https://raw.githubusercontent.com/ChillCube/ChillCube-Developer-Tools/main/templates/ADDONS_TEMPLATE.md"

declare -A CLASS_TO_REPO
declare -A CLASS_TO_ADDON
ALL_CUSTOM_CLASSES=""

echo "🔍 Indexing Project-Wide Class Map..."

# --- 1. GLOBAL PRE-SCAN ---
for addon_path in addons/*; do
    [ -d "$addon_path/.git" ] || continue
    addon_folder=$(basename "$addon_path")
    REPO_URL=$(git -C "$addon_path" remote get-url origin 2>/dev/null | sed 's/\.git$//' | sed 's/git@github\.com:/https:\/\/github\.com\//' | sed 's/ssh:\/\/git@github\.com\//https:\/\/github\.com\//')
    while read -r cname; do
        if [ -n "$cname" ]; then
            CLASS_TO_REPO["$cname"]="$REPO_URL"
            CLASS_TO_ADDON["$cname"]="$addon_folder"
            ALL_CUSTOM_CLASSES+="$cname "
        fi
    done < <(grep -r "class_name" "$addon_path" --include="*.gd" | sed 's/.*class_name //; s/[ \t]*$//; s/ .*//')
done

# --- 2. GENERATION LOOP ---
for addon_path in addons/*; do
    [ -d "$addon_path/.git" ] || continue
    addon_folder=$(basename "$addon_path")
    echo "--------------------------------------------------"
    echo "🚀 Processing: $addon_folder"

    DOC_FILE="$addon_path/DOCUMENTATION.md"
    DEP_FILE="$addon_path/DEPENDENCIES.txt"
    TEMP_DOC=$(mktemp)
    
    declare -A AUTO_DEP_REPOS
    declare -A CLASS_TO_DEP_LINK
    MANUAL_DEPS_CONTENT=""

    # Metadata extraction
    CFG_FILE="$addon_path/plugin.cfg"
    A_NAME=$(grep "name" "$CFG_FILE" 2>/dev/null | head -n 1 | sed 's/.*"\(.*\)".*/\1/')
    [ -z "$A_NAME" ] && A_NAME="$addon_folder"
    A_DESC=$(grep "description" "$CFG_FILE" 2>/dev/null | head -n 1 | sed 's/.*"\(.*\)".*/\1/')
    [ -z "$A_DESC" ] && A_DESC="Godot Addon"
    
    CURRENT_REPO_URL=$(git -C "$addon_path" remote get-url origin 2>/dev/null | sed 's/\.git$//')
    NEW_ENTRY="* [$A_NAME]($CURRENT_REPO_URL) - $A_DESC"

    # --- 3. GLOBAL REGISTRY SYNC (Smart Update Logic) ---
    TEMP_REGISTRY_DIR=$(mktemp -d)
    if git clone --depth 1 "$ORG_REPO" "$TEMP_REGISTRY_DIR" > /dev/null 2>&1; then
        cd "$TEMP_REGISTRY_DIR"
        [ ! -f "$REGISTRY_FILE" ] && curl -s "$REGISTRY_TEMPLATE" > "$REGISTRY_FILE"

        # Check if URL exists in file
        EXISTING_LINE=$(grep -F "($CURRENT_REPO_URL)" "$REGISTRY_FILE")

        if [ -z "$EXISTING_LINE" ]; then
            # NEW ADDON LOGIC
            echo "🆕 $A_NAME is not in the Global Registry."
            mapfile -t CATEGORIES < <(grep "^## " "$REGISTRY_FILE" | sed 's/## //')
            echo "Available Categories:"
            for i in "${!CATEGORIES[@]}"; do printf "  [%d] %s\n" "$((i+1))" "${CATEGORIES[$i]}"; done
            echo "  [0] Create New Category"
            read -p "📁 Select category number or type new name: " CAT_INPUT
            
            if [[ "$CAT_INPUT" =~ ^[0-9]+$ ]] && [ "$CAT_INPUT" -gt 0 ] && [ "$CAT_INPUT" -le "${#CATEGORIES[@]}" ]; then
                SELECTED_CAT="${CATEGORIES[$((CAT_INPUT-1))]}"
            else
                [ "$CAT_INPUT" == "0" ] && read -p "Enter new category name: " SELECTED_CAT || SELECTED_CAT="$CAT_INPUT"
            fi

            if ! grep -q "## $SELECTED_CAT" "$REGISTRY_FILE"; then
                echo -e "\n## $SELECTED_CAT\n$NEW_ENTRY" >> "$REGISTRY_FILE"
            else
                sed -i "/## $SELECTED_CAT/a $NEW_ENTRY" "$REGISTRY_FILE"
            fi
            REGISTRY_UPDATED=1
        elif [ "$EXISTING_LINE" != "$NEW_ENTRY" ]; then
            # UPDATE EXISTING DESCRIPTION/NAME LOGIC
            echo "📝 Updating registry entry for $A_NAME (Description/Name changed)..."
            # Escaping for sed
            ESCAPED_OLD=$(printf '%s\n' "$EXISTING_LINE" | sed 's/[^^]/[&]/g; s/\^/\\^/g')
            ESCAPED_NEW=$(printf '%s\n' "$NEW_ENTRY" | sed 's/[&/\]/\\&/g')
            sed -i "s/$ESCAPED_OLD/$ESCAPED_NEW/" "$REGISTRY_FILE"
            REGISTRY_UPDATED=1
        else
            REGISTRY_UPDATED=0
        fi

        if [ "$REGISTRY_UPDATED" -eq 1 ]; then
            git add "$REGISTRY_FILE"
            git commit -m "registry: update $A_NAME details"
            git push origin main > /dev/null 2>&1
            echo "✅ Global Registry Synchronized."
        fi
        cd "$PROJECT_ROOT"
        rm -rf "$TEMP_REGISTRY_DIR"
    fi

    # --- 4. REBUILD DEPENDENCIES.TXT & DOC TABLE ---
    if [ ${#AUTO_DEP_REPOS[@]} -gt 0 ] || [ -n "$MANUAL_DEPS_CONTENT" ]; then
        echo -e "### 📦 Dependencies\n| Source | Reference | Repository |\n| :--- | :--- | :--- |" >> "$TEMP_DOC"
        echo "# --- Automated Dependencies (Managed by Script) ---" > "$DEP_FILE"
        printf "%s\n" "${!AUTO_DEP_REPOS[@]}" | sort -u >> "$DEP_FILE"
        echo -e "\n$MANUAL_MARKER" >> "$DEP_FILE"
        [ -n "$MANUAL_DEPS_CONTENT" ] && echo "$MANUAL_DEPS_CONTENT" >> "$DEP_FILE"
        IFS=$'\n' sorted_classes=($(sort <<<"${!CLASS_TO_DEP_LINK[*]}")); unset IFS
        for cls in "${sorted_classes[@]}"; do echo "| Code | [\`$cls\`](${CLASS_TO_DEP_LINK[$cls]}) | [Repo](${CLASS_TO_REPO[$cls]}) |" >> "$TEMP_DOC"; done
        if [ -n "$MANUAL_DEPS_CONTENT" ]; then while read -r line; do [[ -z "$line" || "$line" =~ ^# ]] && continue; echo "| Manual | $(basename "$line") | [Repo]($line) |" >> "$TEMP_DOC"; done <<< "$MANUAL_DEPS_CONTENT"; fi
        echo -e "\n---\n" >> "$TEMP_DOC"
    fi
    cat "$BODY_CONTENT" >> "$TEMP_DOC"; rm "$BODY_CONTENT"

    # --- 5. GLOBAL REGISTRY SYNC (Numbered Selection & Template) ---
    TEMP_REGISTRY_DIR=$(mktemp -d)
    if git clone --depth 1 "$ORG_REPO" "$TEMP_REGISTRY_DIR" > /dev/null 2>&1; then
        cd "$TEMP_REGISTRY_DIR"
        # Create from template if missing
        if [ ! -f "$REGISTRY_FILE" ]; then
            echo "📝 Initializing $REGISTRY_FILE from template..."
            curl -s "$REGISTRY_TEMPLATE" > "$REGISTRY_FILE"
        fi
        
        if ! grep -q "$CURRENT_REPO_URL" "$REGISTRY_FILE"; then
            echo "🆕 $A_NAME is not in the Global Registry."
            mapfile -t CATEGORIES < <(grep "^## " "$REGISTRY_FILE" | sed 's/## //')
            
            echo "Available Categories:"
            for i in "${!CATEGORIES[@]}"; do
                printf "  [%d] %s\n" "$((i+1))" "${CATEGORIES[$i]}"
            done
            echo "  [0] Create New Category"
            
            read -p "📁 Select a category number or type a new name: " CAT_INPUT
            
            if [[ "$CAT_INPUT" =~ ^[0-9]+$ ]] && [ "$CAT_INPUT" -gt 0 ] && [ "$CAT_INPUT" -le "${#CATEGORIES[@]}" ]; then
                SELECTED_CAT="${CATEGORIES[$((CAT_INPUT-1))]}"
            elif [ "$CAT_INPUT" == "0" ] || [[ ! "$CAT_INPUT" =~ ^[0-9]+$ ]]; then
                if [ "$CAT_INPUT" == "0" ]; then read -p "Enter new category name: " SELECTED_CAT; else SELECTED_CAT="$CAT_INPUT"; fi
            fi

            if ! grep -q "## $SELECTED_CAT" "$REGISTRY_FILE"; then
                echo -e "\n## $SELECTED_CAT\n* [$A_NAME]($CURRENT_REPO_URL) - $A_DESC" >> "$REGISTRY_FILE"
            else
                sed -i "/## $SELECTED_CAT/a * [$A_NAME]($CURRENT_REPO_URL) - $A_DESC" "$REGISTRY_FILE"
            fi
            
            git add "$REGISTRY_FILE"; git commit -m "registry: add $A_NAME to $SELECTED_CAT"
            git push origin main > /dev/null 2>&1
            echo "✅ Global Registry Updated."
        fi
        cd "$PROJECT_ROOT"; rm -rf "$TEMP_REGISTRY_DIR"
    fi

    # --- 6. FINAL SYNC ---
    if [ ! -f "$DOC_FILE" ] || ! diff <(sed '2d' "$TEMP_DOC") <(sed '2d' "$DOC_FILE") > /dev/null; then
        mv "$TEMP_DOC" "$DOC_FILE"
        cd "$PROJECT_ROOT/$addon_path"
        git add .; git commit -m "docs: auto-update api and registry sync"; super-git-push
        ((UPDATED_COUNT++))
    else
        rm "$TEMP_DOC"
    fi
    cd "$PROJECT_ROOT"
done
echo "--------------------------------------------------"
echo "✅ Finished! $UPDATED_COUNT addons updated."
