#!/usr/bin/env bash

# --- Chillcube Bulk Addon Pusher & Doc Generator ---
TEMPLATE_URL="https://raw.githubusercontent.com/ChillCube/ChillCube-Developer-Tools/main/templates/README_GODOT_ADDON_TEMPLATE.md"
VENV_PATH="/tmp/chillcube_docs_env"

# Ensure environment is ready
if ! command -v godocs &> /dev/null; then
    if [ ! -d "$VENV_PATH" ]; then
        python3 -m venv "$VENV_PATH" &> /dev/null
        "$VENV_PATH/bin/pip" install godocs godocs-jinja --quiet 2>/dev/null || echo "Python venv setup skipped."
    fi
    export PATH="$VENV_PATH/bin:$PATH"
fi

PROJECT_ROOT=$(pwd)

for addon_path in addons/*; do
    [ -d "$addon_path/.git" ] || continue
    addon_folder=$(basename "$addon_path")
    echo "🚀 Processing Addon: $addon_folder"

    # --- 1. METADATA & README ---
    CFG_FILE="$addon_path/plugin.cfg"
    A_NAME=$(grep "name" "$CFG_FILE" | head -n 1 | sed 's/.*"\(.*\)".*/\1/')
    A_DESC=$(grep "description" "$CFG_FILE" | head -n 1 | sed 's/.*"\(.*\)".*/\1/')
    curl -sSL "$TEMPLATE_URL" -o "$addon_path/README.md"
    sed -i "s@{{NAME}}@$A_NAME@g" "$addon_path/README.md"
    sed -i "s@{{DESC}}@$A_DESC@g" "$addon_path/README.md"

    # --- 2. DOCUMENTATION ---
    DOC_FILE="$addon_path/DOCUMENTATION.md"
    TEMP_DOC=$(mktemp)
    echo "# $A_NAME API Reference" > "$TEMP_DOC"
    echo "Generated on: $(date +'%Y-%m-%d')" >> "$TEMP_DOC"
    echo -e "\n$A_DESC\n---\n" >> "$TEMP_DOC"

    mapfile -t SCRIPTS < <(find "$addon_path" -name "*.gd")

    for script in "${SCRIPTS[@]}"; do
        C_NAME=$(grep "class_name" "$script" | sed 's/class_name //' | sed 's/[ \t]*$//')
        [ -z "$C_NAME" ] && C_NAME=$(basename "$script" .gd)

        # Inheritance + Link to Godot Docs
        RAW_EXT=$(grep "^extends " "$script" | sed 's/extends //' | sed 's/[ \t]*$//')
        [ -z "$RAW_EXT" ] && RAW_EXT="Object"
        EXT_LINK="[\`$RAW_EXT\`](https://docs.godotengine.org/en/stable/classes/class_${RAW_EXT,,}.html)"

        CLASS_DESC=$(awk '/^##/ { print substr($0, 4); next } /^[^#]/ { exit }' "$script")
        
        # Properties (Existing State Machine Logic)
        PROP_DATA=$(awk '
            BEGIN { recording = 0; buffer = ""; desc = ""; name = ""; type = ""; }
            /^[ \t]*(@export.*)?var/ && /##/ {
                recording = 1; split($0, parts, "##"); desc = parts[2]; gsub(/^[ \t]+|[ \t]+$/, "", desc);
                code = parts[1]; split(code, n_p, "var "); split(n_p[2], b, /[ :={]/); name = b[1];
                type = "Variant"; if (code ~ /:[ \t]*[A-zA-Z0-9_\[\]]+/) {
                    match(code, /:[ \t]*[A-zA-Z0-9_\[\]]+/); type = substr(code, RSTART+1, RLENGTH-1);
                }
                buffer = code; if (code !~ /\{/ && code !~ /\[/) finish_up();
            }
            recording == 1 && $0 !~ /var/ {
                nl = $0; if (nl ~ /##/) { split(nl, tmp, "##"); nl = tmp[1]; }
                buffer = buffer " " nl;
            }
            recording == 1 && ($0 ~ /\}/ || $0 ~ /\]/) { finish_up(); }
            function finish_up() {
                def = "-"; if (buffer ~ /=/) {
                    eq_idx = index(buffer, "="); after_eq = substr(buffer, eq_idx + 1);
                    b_idx = (after_eq ~ /\{/) ? index(after_eq, "{") : (after_eq ~ /\[/ ? index(after_eq, "[") : 0);
                    def = (b_idx > 0) ? substr(after_eq, b_idx) : after_eq;
                }
                gsub(/[ \t]+/, " ", def); sub(/;[ \t]*$/, "", def); gsub(/^[ \t]+|[ \t]+$/, "", def);
                if (name != "") printf("| **%s** | `%s` | `%s` | %s |\n", name, type, def, desc);
                recording = 0; buffer = ""; name = "";
            }
        ' "$script")

        # Signals (New)
        SIGNAL_DATA=$(awk '/signal .*##/ {
            line = $0; split(line, p, "##"); d = p[2]; gsub(/^[ \t]+|[ \t]+$/, "", d);
            code = p[1]; split(code, a, "signal "); split(a[2], b, /[ (]/); n = b[1];
            printf("| **%s** | %s |\n", n, d);
        }' "$script")

        # Methods (Existing Logic)
        METHOD_DATA=$(awk '/func .*##/ {
            line = $0; split(line, p, "##"); d = p[2]; gsub(/^[ \t]+|[ \t]+$/, "", d);
            code = p[1]; split(code, a, "func "); split(a[2], b, "("); n = b[1];
            if (n == "" || n ~ /^_/) next;
            ret = "void"; if (code ~ /->/) { split(code, c, "->"); split(c[2], d_ret, ":"); ret = d_ret[1]; gsub(/[ \t]+/, "", ret); }
            printf("| **%s()** | `%s` | %s |\n", n, ret, d);
        }' "$script")

        if [ -n "$CLASS_DESC" ] || [ -n "$PROP_DATA" ] || [ -n "$METHOD_DATA" ] || [ -n "$SIGNAL_DATA" ]; then
            echo -e "\n## Class: $C_NAME" >> "$TEMP_DOC"
            echo -e "**Inherits:** $EXT_LINK\n" >> "$TEMP_DOC"
            [ -n "$CLASS_DESC" ] && echo -e "$CLASS_DESC\n" >> "$TEMP_DOC"
            [ -n "$PROP_DATA" ] && echo -e "### Properties\n| Property | Type | Default | Description |\n| :--- | :--- | :--- | :--- |\n$PROP_DATA\n" >> "$TEMP_DOC"
            [ -n "$SIGNAL_DATA" ] && echo -e "### Signals\n| Signal | Description |\n| :--- | :--- |\n$SIGNAL_DATA\n" >> "$TEMP_DOC"
            [ -n "$METHOD_DATA" ] && echo -e "### Methods\n| Method | Returns | Description |\n| :--- | :--- | :--- |\n$METHOD_DATA\n" >> "$TEMP_DOC"
            echo "---" >> "$TEMP_DOC"
        fi
    done

    # --- 3. GIT SYNC ---
    if [ ! -f "$DOC_FILE" ] || ! diff <(sed '2d' "$TEMP_DOC") <(sed '2d' "$DOC_FILE") > /dev/null; then
        mv "$TEMP_DOC" "$DOC_FILE"
        cd "$PROJECT_ROOT/$addon_path"
        git add .
        git commit -m "docs($addon_folder): automated api update with signals"
        if command -v super-git-push &> /dev/null; then super-git-push; else git push origin main; fi
    fi
    cd "$PROJECT_ROOT"
done
