#!/usr/bin/env bash

# --- Chillcube Universal Doc & Registry Engine (v6.6) ---
PROJECT_ROOT=$(pwd)
UPDATED_COUNT=0
AUTO_MARKER="# --- Automated Dependencies (Managed by Script) ---"
MANUAL_MARKER="# --- Manual Dependencies (Do Not Delete) ---"
ORG_REPO="https://github.com/ChillCube/.github.git"
REGISTRY_FILE="ADDONS.md"
TEMPLATE_URL="https://raw.githubusercontent.com/ChillCube/ChillCube-Developer-Tools/main/templates/README_GODOT_ADDON_TEMPLATE.md"

declare -A CLASS_TO_REPO
declare -A CLASS_TO_ADDON

# --- 1. GLOBAL PRE-SCAN ---
for addon_path in addons/*; do
    [ -d "$addon_path/.git" ] || continue
    addon_folder=$(basename "$addon_path")
    REPO_URL=$(git -C "$addon_path" remote get-url origin 2>/dev/null | sed 's/\.git$//' | sed 's/git@github\.com:/https:\/\/github\.com\//' | sed 's/ssh:\/\/git@github\.com\//https:\/\/github\.com\//')
    
    while read -r cname; do
        if [ -n "$cname" ]; then
            CLASS_TO_REPO["$cname"]="$REPO_URL"
            CLASS_TO_ADDON["$cname"]="$addon_folder"
        fi
    done < <(grep -r "class_name" "$addon_path" --include="*.gd" | sed 's/.*class_name //; s/[ \t]*$//; s/ .*//')
done

# --- 2. GENERATION LOOP ---
for addon_path in addons/*; do
    [ -d "$addon_path/.git" ] || continue
    addon_folder=$(basename "$addon_path")
    
    README_FILE="$addon_path/README.md"
    DOC_FILE="$addon_path/DOCUMENTATION.md"
    DEP_FILE="$addon_path/DEPENDENCIES.txt"
    TEMP_DOC=$(mktemp)
    TEMP_README=$(mktemp)
    
    CFG_FILE="$addon_path/plugin.cfg"
    [ ! -f "$CFG_FILE" ] && continue
    
    A_NAME=$(grep "name" "$CFG_FILE" | head -n 1 | sed 's/.*"\(.*\)".*/\1/')
    [ -z "$A_NAME" ] && A_NAME="$addon_folder"
    A_DESC=$(grep "description" "$CFG_FILE" | head -n 1 | sed 's/.*"\(.*\)".*/\1/')
    A_AUTHOR=$(grep "author" "$CFG_FILE" | head -n 1 | sed 's/.*"\(.*\)".*/\1/')
    YEAR=$(date +%Y)
    CURRENT_REPO_URL=$(git -C "$addon_path" remote get-url origin 2>/dev/null | sed 's/\.git$//')

    # --- 3. REGISTRY SYNC (Interactive) ---
    TEMP_REGISTRY_DIR=$(mktemp -d)
    if git clone --depth 1 "$ORG_REPO" "$TEMP_REGISTRY_DIR" > /dev/null 2>&1; then
        cd "$TEMP_REGISTRY_DIR"
        [ ! -f "$REGISTRY_FILE" ] && { echo "# 🧊 ChillCube Addon Registry" > "$REGISTRY_FILE"; echo -e "\n## Uncategorized" >> "$REGISTRY_FILE"; }
        if ! grep -q "$CURRENT_REPO_URL" "$REGISTRY_FILE"; then
            mapfile -t CATEGORIES < <(grep "^## " "$REGISTRY_FILE" | sed 's/## //')
            for i in "${!CATEGORIES[@]}"; do printf "  [%d] %s\n" "$((i+1))" "${CATEGORIES[$i]}"; done
            read -p "📁 Category # for $A_NAME: " CAT_INPUT
            if [[ "$CAT_INPUT" =~ ^[0-9]+$ ]] && [ "$CAT_INPUT" -gt 0 ] && [ "$CAT_INPUT" -le "${#CATEGORIES[@]}" ]; then
                SELECTED_CAT="${CATEGORIES[$((CAT_INPUT-1))]}"
            else
                [ "$CAT_INPUT" == "0" ] && read -p "Name: " SELECTED_CAT || SELECTED_CAT="$CAT_INPUT"
            fi
            ENTRY="* [$A_NAME]($CURRENT_REPO_URL) - $A_DESC"
            if ! grep -q "## $SELECTED_CAT" "$REGISTRY_FILE"; then echo -e "\n## $SELECTED_CAT\n$ENTRY" >> "$REGISTRY_FILE"; else sed -i "/## $SELECTED_CAT/a $ENTRY" "$REGISTRY_FILE"; fi
            git add "$REGISTRY_FILE" && git commit -m "registry: add $A_NAME" && git push origin main > /dev/null 2>&1
        fi
        cd "$PROJECT_ROOT" && rm -rf "$TEMP_REGISTRY_DIR"
    fi

    # --- 4. DEPENDENCY FILE UPDATE ---
    MANUAL_DEPS=""
    if [ -f "$DEP_FILE" ] && grep -q "$MANUAL_MARKER" "$DEP_FILE"; then
        MANUAL_DEPS=$(sed -n "/$MANUAL_MARKER/,\$p" "$DEP_FILE")
    fi

    AUTO_DEPS_URLS=""
    while read -r line; do
        for cname in "${!CLASS_TO_REPO[@]}"; do
            if [[ "$line" == *"$cname"* ]] && [[ "${CLASS_TO_ADDON[$cname]}" != "$addon_folder" ]]; then
                URL="${CLASS_TO_REPO[$cname]}"
                [[ "$AUTO_DEPS_URLS" != *"$URL"* ]] && AUTO_DEPS_URLS+="$URL"$'\n'
            fi
        done
    done < <(grep -r "" "$addon_path" --include="*.gd")

    {
        echo "$AUTO_MARKER"
        echo -e "$AUTO_DEPS_URLS"
        [ -n "$MANUAL_DEPS" ] && echo "$MANUAL_DEPS" || echo -e "\n$MANUAL_MARKER\n# Add non-Godot dependencies below"
    } > "$DEP_FILE"

    # --- 5. README & DOCUMENTATION GENERATION ---
    curl -sSL "$TEMPLATE_URL" -o "$TEMP_README"
    sed -i "s|{{NAME}}|$A_NAME|g" "$TEMP_README"
    sed -i "s|{{DESC}}|$A_DESC|g" "$TEMP_README"
    sed -i "s|{{AUTHOR}}|$A_AUTHOR|g" "$TEMP_README"
    sed -i "s|{{YEAR}}|$YEAR|g" "$TEMP_README"
    sed -i "s|clone-gd-addon.*|clone-gd-addon $CURRENT_REPO_URL.git|g" "$TEMP_README"

    echo "# $A_NAME API Reference" > "$TEMP_DOC"
    echo -e "Generated: $(date +'%Y-%m-%d')\n\n$A_DESC\n" >> "$TEMP_DOC"

    # --- THE DEPENDENCY TABLE (CORRECTED) ---
    if [ -n "$AUTO_DEPS_URLS" ] || [ -n "$(echo "$MANUAL_DEPS" | grep -v "$MANUAL_MARKER")" ]; then
        echo -e "### 📦 Dependencies\n" >> "$TEMP_DOC"
        echo -e "| Source | Reference | Repository |" >> "$TEMP_DOC"
        echo -e "| :--- | :--- | :--- |" >> "$TEMP_DOC"

        # Automated Loop
        while read -r url; do
            [ -z "$url" ] && continue
            DEP_FOLDER=$(basename "$url" | sed 's/\.git$//')
            REF_NAME=$(echo "$DEP_FOLDER" | sed 's/Godot_//g')
            DOC_LINK="${url}/blob/main/DOCUMENTATION.md"
            echo "| Code | [\`$REF_NAME\`]($DOC_LINK) | [Repo]($url) |" >> "$TEMP_DOC"
        done <<< "$AUTO_DEPS_URLS"

        # Manual Loop
        if [ -n "$MANUAL_DEPS" ]; then
            while read -r m_url; do
                [[ "$m_url" =~ ^http ]] || continue
                M_DEP_NAME=$(basename "$m_url" | sed 's/\.git$//')
                M_DOC_LINK="${m_url}/blob/main/DOCUMENTATION.md"
                echo "| Manual | [\`$M_DEP_NAME\`]($M_DOC_LINK) | [Repo]($m_url) |" >> "$TEMP_DOC"
            done <<< "$(echo "$MANUAL_DEPS" | grep -v "$MANUAL_MARKER")"
        fi
        echo -e "\n---\n" >> "$TEMP_DOC"
    fi

    # --- CLASS SCANNING ---
    BODY_CONTENT=$(mktemp)
    while IFS= read -r -d '' script; do
        C_NAME=$(grep "class_name" "$script" | sed 's/class_name //' | sed 's/ .*//'); [ -z "$C_NAME" ] && C_NAME=$(basename "$script" .gd)
        INHERITS=$(grep "^extends " "$script" | sed 's/extends //; s/[ \t]*$//')
        
        INHERITS_LINK=""
        if [ -n "$INHERITS" ]; then
            if [[ -n "${CLASS_TO_REPO[$INHERITS]}" ]]; then
                if [[ "${CLASS_TO_ADDON[$INHERITS]}" == "$addon_folder" ]]; then
                    INHERITS_LINK="[${INHERITS}](#class-${INHERITS,,})"
                else
                    INHERITS_LINK="[${INHERITS}](${CLASS_TO_REPO[$INHERITS]}/blob/main/DOCUMENTATION.md)"
                fi
            else
                INHERITS_LINK="[${INHERITS}](https://docs.godotengine.org/en/stable/classes/class_${INHERITS,,}.html)"
            fi
        fi

        {
            echo -e "## Class: $C_NAME"
            [ -n "$INHERITS_LINK" ] && echo -e "**Inherits:** $INHERITS_LINK\n" || echo ""
            awk '/^##/ { print substr($0, 4); next } /^[^#]/ { exit }' "$script"
            echo ""

            # EXPORTS
            EXPD=$(awk 'BEGIN{r=0;b="";d="";n="";t=""} index($0, "var") > 0 && index($0, "##") > 0 && index($0, "@export") > 0 { 
                r=1; split($0,p,"##"); d=p[2]; sub(/^[ \t]*/,"",d); 
                line=p[1]; sub(/^[ \t]*/,"",line); 
                split(line, parts, "var "); split(parts[2], name_part, " "); 
                split(name_part[1], name_final, ":"); n=name_final[1]; 
                t="Variant"; ci=index(line, ":"); 
                if(ci > 0) { remainder=substr(line, ci+1); sub(/^[ \t]*/,"",remainder); split(remainder, type_part, " "); split(type_part[1], type_final, "="); t=type_final[1]; } 
                b=line; f() 
            } 
            function f(){ 
                dv="-"; if(index(b,"=") > 0){ split(b, val_parts, "="); dv=val_parts[2]; } 
                sub(/^[ \t]*/,"",dv); sub(/[ \t]*[:;][ \t]*$/, "", dv); sub(/[ \t]*$/, "", dv); 
                if(n!="") printf("| **%s** | \140%s\140 | \140%s\140 | %s |\n", n, t, dv, d); 
                r=0; b=""; n="" 
            }' "$script")
            [ -n "$EXPD" ] && echo -e "### ⚙️ Inspector Variables (Exported)\n| Property | Type | Default | Description |\n| :--- | :--- | :--- | :--- |\n$EXPD\n"

            # STANDARD VARS
            STPD=$(awk 'BEGIN{r=0;b="";d="";n="";t=""} index($0, "var") > 0 && index($0, "##") > 0 && index($0, "@export") == 0 { 
                r=1; split($0,p,"##"); d=p[2]; sub(/^[ \t]*/,"",d); 
                line=p[1]; sub(/^[ \t]*/,"",line); 
                split(line, parts, "var "); split(parts[2], name_part, " "); 
                split(name_part[1], name_final, ":"); n=name_final[1]; 
                t="Variant"; ci=index(line, ":"); 
                if(ci > 0) { remainder=substr(line, ci+1); sub(/^[ \t]*/,"",remainder); split(remainder, type_part, " "); split(type_part[1], type_final, "="); t=type_final[1]; } 
                b=line; f() 
            } 
            function f(){ 
                dv="-"; if(index(b,"=") > 0){ split(b, val_parts, "="); dv=val_parts[2]; } 
                sub(/^[ \t]*/,"",dv); sub(/[ \t]*[:;][ \t]*$/, "", dv); sub(/[ \t]*$/, "", dv); 
                if(n!="") printf("| **%s** | \140%s\140 | \140%s\140 | %s |\n", n, t, dv, d); 
                r=0; b=""; n="" 
            }' "$script")
            [ -n "$STPD" ] && echo -e "### 💾 Class Variables (Standard)\n| Property | Type | Default | Description |\n| :--- | :--- | :--- | :--- |\n$STPD\n"

            # SIGNALS
            SD=$(awk 'index($0, "signal") > 0 && index($0, "##") > 0 { 
                split($0,p,"##"); d=p[2]; code=p[1]; 
                sub(/^[ \t]*signal /, "", code); sub(/[ \t]*$/, "", code);
                name=code; args="-";
                if(index(code, "(") > 0) {
                    split(code, arr, "("); name=arr[1]; raw_args=arr[2]; sub(/\).*/, "", raw_args);
                    gsub(/,[ \t]*/, "\140<br>\140", raw_args); args="\140" raw_args "\140"
                }
                printf("| **%s** | %s | %s |\n", name, args, d) 
            }' "$script")
            [ -n "$SD" ] && echo -e "### 🔔 Signals\n| Signal | Arguments | Description |\n| :--- | :--- | :--- |\n$SD\n"

            # METHODS
            MD=$(awk 'index($0, "func") > 0 && index($0, "##") > 0 { 
                split($0,p,"##"); d=p[2]; code=p[1]; 
                sub(/^[ \t]*func /, "", code); sub(/[ \t]*$/, "", code);
                split(code, parts, "("); name=parts[1];
                if(index(name, "_") == 1) next;
                raw_args=parts[2]; sub(/\).*/, "", raw_args); 
                if(raw_args=="") args="-"; else { gsub(/,[ \t]*/, "\140<br>\140", raw_args); args="\140" raw_args "\140" }
                ret="void"; 
                if(index(code, "->") > 0) { split(code, c, "->"); ret=c[2]; sub(/[ \t]*[:;][ \t]*$/, "", ret); gsub(/[ \t]+/, "", ret); }
                printf("| **%s()** | %s | \140%s\140 | %s |\n", name, args, ret, d) 
            }' "$script")
            [ -n "$MD" ] && echo -e "### 🛠️ Methods\n| Method | Arguments | Returns | Description |\n| :--- | :--- | :--- | :--- |\n$MD\n"
            echo -e "---\n"
        } >> "$BODY_CONTENT"
    done < <(find "$addon_path" -name "*.gd" -print0)
    cat "$BODY_CONTENT" >> "$TEMP_DOC" && rm -f "$BODY_CONTENT"

    # --- 6. FINAL SYNC & SUPER-PUSH ---
    cp "$TEMP_README" "$README_FILE"
    if [ ! -f "$DOC_FILE" ] || ! diff <(sed '2d' "$TEMP_DOC") <(sed '2d' "$DOC_FILE") > /dev/null; then
        mv "$TEMP_DOC" "$DOC_FILE"
    fi

    cd "$PROJECT_ROOT/$addon_path"
    if [[ -n $(git status -s) ]]; then
        git add .
        git commit -m "docs: auto-sync v6.6 (corrected dependency tables)"
        super-git-push
        ((UPDATED_COUNT++))
    fi
    cd "$PROJECT_ROOT"
    rm -f "$TEMP_README" "$TEMP_DOC"
done
echo "✅ Finished! $UPDATED_COUNT updated."
