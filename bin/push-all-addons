#!/usr/bin/env bash

# --- Chillcube Bulk Addon Pusher & Doc Generator ---
TEMPLATE_URL="https://raw.githubusercontent.com/ChillCube/ChillCube-Developer-Tools/main/templates/README_GODOT_ADDON_TEMPLATE.md"
VENV_PATH="/tmp/chillcube_docs_env"

# Ensure environment is ready
if ! command -v godocs &> /dev/null; then
    if [ ! -d "$VENV_PATH" ]; then
        python3 -m venv "$VENV_PATH" &> /dev/null
        "$VENV_PATH/bin/pip" install godocs godocs-jinja --quiet 2>/dev/null || echo "Python venv setup skipped."
    fi
    export PATH="$VENV_PATH/bin:$PATH"
fi

PROJECT_ROOT=$(pwd)

if [ ! -d "addons" ]; then
    echo "❌ Error: No addons/ folder found in $(pwd)"
    exit 1
fi

for addon_path in addons/*; do
    [ -d "$addon_path/.git" ] || continue
    addon_folder=$(basename "$addon_path")
    
    echo "--------------------------------------------------"
    echo "🚀 Processing Addon: $addon_folder"

    # --- 1. SCRAPE METADATA ---
    CFG_FILE="$addon_path/plugin.cfg"
    if [ -f "$CFG_FILE" ]; then
        A_NAME=$(grep "name" "$CFG_FILE" | head -n 1 | sed 's/.*"\(.*\)".*/\1/')
        A_DESC=$(grep "description" "$CFG_FILE" | head -n 1 | sed 's/.*"\(.*\)".*/\1/')
        A_AUTH=$(grep "author" "$CFG_FILE" | head -n 1 | sed 's/.*"\(.*\)".*/\1/')
    else
        A_NAME="$addon_folder"; A_DESC="Godot Addon"; A_AUTH="ChillCube"
    fi

    # --- 2. REGENERATE README ---
    curl -sSL "$TEMPLATE_URL" -o "$addon_path/README.md"
    sed -i "s@{{NAME}}@$A_NAME@g" "$addon_path/README.md"
    sed -i "s@{{DESC}}@$A_DESC@g" "$addon_path/README.md"
    sed -i "s@{{AUTHOR}}@$A_AUTH@g" "$addon_path/README.md"
    sed -i "s@{{YEAR}}@$(date +%Y)@g" "$addon_path/README.md"

    # --- 3. GENERATE API REFERENCE ---
    DOC_FILE="$addon_path/DOCUMENTATION.md"
    TEMP_DOC=$(mktemp)
    
    echo "# $A_NAME API Reference" > "$TEMP_DOC"
    echo "Generated on: $(date +'%Y-%m-%d')" >> "$TEMP_DOC"
    echo -e "\n$A_DESC\n" >> "$TEMP_DOC"
    echo "---" >> "$TEMP_DOC"

    # Find ALL .gd files in the addon
    mapfile -t SCRIPTS < <(find "$addon_path" -name "*.gd")

    for script in "${SCRIPTS[@]}"; do
        # Extract class_name or use filename
        C_NAME=$(grep "class_name" "$script" | sed 's/class_name //' | sed 's/[ \t]*$//')
        [ -z "$C_NAME" ] && C_NAME=$(basename "$script" .gd)

        # Pre-parse sections to see if script has documented items
        CLASS_DESC=$(awk '/^##/ { print substr($0, 4); next } /^[^#]/ { exit }' "$script")
        
        PROP_DATA=$(awk '/var/ && /##/ {
            full_line = $0; split(full_line, parts, "##"); desc = parts[2]; gsub(/^[ \t]+|[ \t]+$/, "", desc)
            code = parts[1]; gsub(/@export(_[a-z_]+)?(\(.*\))?/, "", code); gsub(/^[ \t]+|[ \t]+$/, "", code)
            name = ""; split(code, a, "var "); split(a[2], b, /[ :={]/); name = b[1]
            if (name == "") next
            type = "Variant"
            if (code ~ /:[ \t]*[A-zA-Z0-9_\[\]]+/) {
                sub(/.*:[ \t]*/, "", code); split(code, t_parts, /[ =;]/); type = t_parts[1]
            } else if (parts[1] ~ /:=/) {
                if (parts[1] ~ /"/) type = "String"; else if (parts[1] ~ /true|false/) type = "bool";
                else if (parts[1] ~ /[0-9]+\.[0-9]+/) type = "float"; else if (parts[1] ~ /[0-9]+/) type = "int"
            }
            def = "-"; code_for_def = parts[1]
            if (code_for_def ~ /:=/) { split(code_for_def, d_parts, ":="); def = d_parts[2]; }
            else if (code_for_def ~ /=/) { split(code_for_def, d_parts, "="); def = d_parts[2]; }
            gsub(/^[ \t;]+|[ \t;]+$/, "", def)
            printf("| **%s** | `%s` | `%s` | %s |\n", name, type, def, desc)
        }' "$script")

        METHOD_DATA=$(awk '/func .*##/ {
            line = $0; split(line, p, "##"); desc = p[2]; gsub(/^[ \t]+|[ \t]+$/, "", desc); code = p[1];
            split(code, a, "func "); split(a[2], b, "("); name = b[1];
            if (name == "" || name ~ /^_/) next;
            ret = "void"; if (code ~ /->/) { split(code, c, "->"); split(c[2], d, ":"); ret = d[1]; gsub(/[ \t]+/, "", ret); }
            printf("| **%s()** | `%s` | %s |\n", name, ret, desc);
        }' "$script")

        SIGNAL_DATA=$(awk '/signal .*##/ {
            line = $0; split(line, p, "##"); desc = p[2]; gsub(/^[ \t]+|[ \t]+$/, "", desc); code = p[1];
            split(code, a, "signal "); split(a[2], b, /[ (]/); name = b[1];
            printf("| **%s** | %s |\n", name, desc);
        }' "$script")

        # Only add the script to the DOCS if it has documented content
        if [ -n "$CLASS_DESC" ] || [ -n "$PROP_DATA" ] || [ -n "$METHOD_DATA" ] || [ -n "$SIGNAL_DATA" ]; then
            echo -e "\n## Class: $C_NAME" >> "$TEMP_DOC"
            [ -n "$CLASS_DESC" ] && echo -e "$CLASS_DESC\n" >> "$TEMP_DOC"
            
            if [ -n "$PROP_DATA" ]; then
                echo -e "### Properties\n| Property | Type | Default | Description |\n| :--- | :--- | :--- | :--- |" >> "$TEMP_DOC"
                echo "$PROP_DATA" >> "$TEMP_DOC"; echo "" >> "$TEMP_DOC"
            fi
            if [ -n "$METHOD_DATA" ]; then
                echo -e "### Methods\n| Method | Returns | Description |\n| :--- | :--- | :--- |" >> "$TEMP_DOC"
                echo "$METHOD_DATA" >> "$TEMP_DOC"; echo "" >> "$TEMP_DOC"
            fi
            if [ -n "$SIGNAL_DATA" ]; then
                echo -e "### Signals\n| Signal | Description |\n| :--- | :--- |" >> "$TEMP_DOC"
                echo "$SIGNAL_DATA" >> "$TEMP_DOC"; echo "" >> "$TEMP_DOC"
            fi
            echo "---" >> "$TEMP_DOC"
        fi
    done

    # --- 4. COMMIT AND PUSH ---
    if [ ! -f "$DOC_FILE" ] || ! diff <(sed '2d' "$TEMP_DOC") <(sed '2d' "$DOC_FILE") > /dev/null; then
        mv "$TEMP_DOC" "$DOC_FILE"
        cd "$PROJECT_ROOT/$addon_path"
        git add README.md DOCUMENTATION.md
        echo -e "\n💬 Documentation updated for [$addon_folder]."
        read -p "Commit message (default: docs update): " msg
        git commit -m "docs($addon_folder): ${msg:-docs update}"
        if command -v super-git-push &> /dev/null; then super-git-push; else git push origin main; fi
    else
        echo "ℹ️  No changes detected for $addon_folder."
        rm "$TEMP_DOC"
    fi
    cd "$PROJECT_ROOT"
done
