#!/usr/bin/env bash

# --- Chillcube Bulk Addon Pusher & Doc Generator ---
TEMPLATE_URL="https://raw.githubusercontent.com/ChillCube/ChillCube-Developer-Tools/main/templates/README_GODOT_ADDON_TEMPLATE.md"
VENV_PATH="/tmp/chillcube_docs_env"

# Ensure environment is ready
if ! command -v godocs &> /dev/null; then
    if [ ! -d "$VENV_PATH" ]; then
        python3 -m venv "$VENV_PATH" &> /dev/null
        "$VENV_PATH/bin/pip" install godocs godocs-jinja --quiet 2>/dev/null || echo "Python venv setup skipped."
    fi
    export PATH="$VENV_PATH/bin:$PATH"
fi

PROJECT_ROOT=$(pwd)

# --- NEW: GLOBAL PRE-SCAN ---
# We build a map of every class_name in the entire addons/ folder
echo "🔍 Scanning project for custom classes..."
declare -A CLASS_MAP
while read -r line; do
    # Format: "ClassName:AddonFolderName"
    cname=$(echo "$line" | cut -d':' -f1)
    afolder=$(echo "$line" | cut -d':' -f2)
    CLASS_MAP["$cname"]="$afolder"
done < <(find addons -name "*.gd" -exec grep -H "class_name" {} + | sed -E 's/addons\/([^/]+)\/.*class_name ([a-zA-Z0-9_]+).*/\2:\1/')

for addon_path in addons/*; do
    [ -d "$addon_path/.git" ] || continue
    addon_folder=$(basename "$addon_path")
    echo "--------------------------------------------------"
    echo "🚀 Processing Addon: $addon_folder"

    # --- 1. METADATA & README ---
    CFG_FILE="$addon_path/plugin.cfg"
    A_NAME=$(grep "name" "$CFG_FILE" | head -n 1 | sed 's/.*"\(.*\)".*/\1/')
    A_DESC=$(grep "description" "$CFG_FILE" | head -n 1 | sed 's/.*"\(.*\)".*/\1/')
    curl -sSL "$TEMPLATE_URL" -o "$addon_path/README.md"
    sed -i "s@{{NAME}}@$A_NAME@g" "$addon_path/README.md"
    sed -i "s@{{DESC}}@$A_DESC@g" "$addon_path/README.md"

    # --- 2. DOCUMENTATION ---
    DOC_FILE="$addon_path/DOCUMENTATION.md"
    TEMP_DOC=$(mktemp)
    echo "# $A_NAME API Reference" > "$TEMP_DOC"
    echo "Generated on: $(date +'%Y-%m-%d')" >> "$TEMP_DOC"
    echo -e "\n$A_DESC\n---\n" >> "$TEMP_DOC"

    mapfile -t SCRIPTS < <(find "$addon_path" -name "*.gd")

    for script in "${SCRIPTS[@]}"; do
        C_NAME=$(grep "class_name" "$script" | sed 's/class_name //' | sed 's/[ \t]*$//')
        [ -z "$C_NAME" ] && C_NAME=$(basename "$script" .gd)

        # --- SMART INHERITANCE LINKING ---
        RAW_EXT=$(grep "^extends " "$script" | sed 's/extends //' | sed 's/[ \t]*$//')
        [ -z "$RAW_EXT" ] && RAW_EXT="Object"
        
        # Check if the parent class exists in our Global Map
        PARENT_ADDON="${CLASS_MAP[$RAW_EXT]}"
        
        if [ -n "$PARENT_ADDON" ]; then
            if [ "$PARENT_ADDON" == "$addon_folder" ]; then
                # Internal Link (Same document)
                EXT_LINK="[\`$RAW_EXT\`](#class-$RAW_EXT)"
            else
                # External Link (Dependency in another addon)
                # This assumes the other addon has a DOCUMENTATION.md in its root
                EXT_LINK="[\`$RAW_EXT\`](../$PARENT_ADDON/DOCUMENTATION.md#class-$RAW_EXT)"
            fi
        elif [[ "$RAW_EXT" =~ ^[A-Z] ]] && [[ ! "$RAW_EXT" =~ [./\"] ]]; then
            # Godot Engine Link
            EXT_LINK="[\`$RAW_EXT\`](https://docs.godotengine.org/en/stable/classes/class_${RAW_EXT,,}.html)"
        else
            # Unknown / Path-based
            EXT_LINK="\`$RAW_EXT\`"
        fi

        CLASS_DESC=$(awk '/^##/ { print substr($0, 4); next } /^[^#]/ { exit }' "$script")
        
        # [Property, Signal, and Method logic remains the same stable state-machine]
        # (Shortened here for brevity, keep your existing AWK logic blocks)
        PROP_DATA=$(awk 'BEGIN{recording=0;buffer="";desc="";name="";type=""} /^[ \t]*(@export.*)?var/ && /##/ { recording=1; split($0,p,"##"); desc=p[2]; gsub(/^[ \t]+|[ \t]+$/,"",desc); code=p[1]; split(code,np,"var "); split(np[2],b,/[ :={]/); name=b[1]; type="Variant"; if(code~/:[ \t]*[A-zA-Z0-9_\[\]]+/){match(code,/:[ \t]*[A-zA-Z0-9_\[\]]+/); type=substr(code,RSTART+1,RLENGTH-1)} buffer=code; if(code!~"{" && code!~"[") finish_up() } recording==1 && $0!~"var" { nl=$0; if(nl~"##"){split(nl,tmp,"##"); nl=tmp[1]} buffer=buffer " " nl } recording==1 && ($0~"}" || $0~"]") { finish_up() } function finish_up(){ def="-"; if(buffer~"="){ ei=index(buffer,"="); ae=substr(buffer,ei+1); bi=(ae~"{")?index(ae,"{"):(ae~"["?index(ae,"["):0); def=(bi>0)?substr(ae,bi):ae } gsub(/[ \t]+/," ",def); sub(/;[ \t]*$/,"",def); gsub(/^[ \t]+|[ \t]+$/,"",def); if(name!="") printf("| **%s** | `%s` | `%s` | %s |\n",name,type,def,desc); recording=0; buffer=""; name="" }' "$script")
        SIGNAL_DATA=$(awk '/signal .*##/ { line=$0; split(line,p,"##"); d=p[2]; gsub(/^[ \t]+|[ \t]+$/,"",d); code=p[1]; split(code,a,"signal "); split(a[2],b,/[ (]/); n=b[1]; printf("| **%s** | %s |\n",n,d) }' "$script")
        METHOD_DATA=$(awk '/func .*##/ { line=$0; split(line,p,"##"); d=p[2]; gsub(/^[ \t]+|[ \t]+$/, "", d); code=p[1]; split(code, a, "func "); split(a[2], b, "("); n=b[1]; if(n=="" || n~"^_") next; ret="void"; if(code~"->") { split(code, c, "->"); split(c[2], dr, ":"); ret=dr[1]; gsub(/[ \t]+/,"",ret) } printf("| **%s()** | `%s` | %s |\n", n, ret, d) }' "$script")

        if [ -n "$CLASS_DESC" ] || [ -n "$PROP_DATA" ] || [ -n "$METHOD_DATA" ] || [ -n "$SIGNAL_DATA" ]; then
            echo -e "\n## Class: $C_NAME" >> "$TEMP_DOC"
            echo -e "**Inherits:** $EXT_LINK\n" >> "$TEMP_DOC"
            [ -n "$CLASS_DESC" ] && echo -e "$CLASS_DESC\n" >> "$TEMP_DOC"
            [ -n "$PROP_DATA" ] && echo -e "### Properties\n| Property | Type | Default | Description |\n| :--- | :--- | :--- | :--- |\n$PROP_DATA\n" >> "$TEMP_DOC"
            [ -n "$SIGNAL_DATA" ] && echo -e "### Signals\n| Signal | Description |\n| :--- | :--- |\n$SIGNAL_DATA\n" >> "$TEMP_DOC"
            [ -n "$METHOD_DATA" ] && echo -e "### Methods\n| Method | Returns | Description |\n| :--- | :--- | :--- |\n$METHOD_DATA\n" >> "$TEMP_DOC"
            echo "---" >> "$TEMP_DOC"
        fi
    done

    # --- 3. GIT SYNC ---
    if [ ! -f "$DOC_FILE" ] || ! diff <(sed '2d' "$TEMP_DOC") <(sed '2d' "$DOC_FILE") > /dev/null; then
        mv "$TEMP_DOC" "$DOC_FILE"
        cd "$PROJECT_ROOT/$addon_path"
        git add .
        git commit -m "docs($addon_folder): global cross-addon inheritance support"
        if command -v super-git-push &> /dev/null; then super-git-push; else git push origin main; fi
    else
        rm "$TEMP_DOC"
    fi
    cd "$PROJECT_ROOT"
done
