#!/usr/bin/env bash

# --- Chillcube Universal Doc & Registry Engine (v6.4) ---
PROJECT_ROOT=$(pwd)
UPDATED_COUNT=0

echo "🔍 Indexing Project-Wide Class Map..."

# --- 1. GENERATION LOOP ---
for addon_path in addons/*; do
    [ -d "$addon_path/.git" ] || continue
    addon_folder=$(basename "$addon_path")
    echo "--------------------------------------------------"
    echo "🚀 Processing: $addon_folder"

    DOC_FILE="$addon_path/DOCUMENTATION.md"
    TEMP_DOC=$(mktemp)
    
    CFG_FILE="$addon_path/plugin.cfg"
    [ ! -f "$CFG_FILE" ] && continue
    A_NAME=$(grep "name" "$CFG_FILE" | head -n 1 | sed 's/.*"\(.*\)".*/\1/')
    A_DESC=$(grep "description" "$CFG_FILE" | head -n 1 | sed 's/.*"\(.*\)".*/\1/')
    [ -z "$A_DESC" ] && A_DESC="Godot Addon"
    
    echo "# $A_NAME API Reference" > "$TEMP_DOC"
    echo -e "Generated: $(date +'%Y-%m-%d')\n\n$A_DESC\n" >> "$TEMP_DOC"
    BODY_CONTENT=$(mktemp)
    mapfile -t SCRIPTS < <(find "$addon_path" -name "*.gd")

    for script in "${SCRIPTS[@]}"; do
        C_NAME=$(grep "class_name" "$script" | sed 's/class_name //' | sed 's/ .*//'); [ -z "$C_NAME" ] && C_NAME=$(basename "$script" .gd)
        {
            echo -e "## Class: $C_NAME\n"
            # Extract Class Description
            awk '/^##/ { print substr($0, 4); next } /^[^#]/ { exit }' "$script"
            echo ""
            
            # --- THE STATEFUL PARSER ---
            awk -v bt_code="\140" '
            function colorize(raw) {
                if (raw == "" || raw == "-") return "-";
                n_args = split(raw, arr, ",[ \t]*");
                colors[0]="#56b6c2"; colors[1]="#d19a66"; colors[2]="#c678dd"; colors[3]="#98c379";
                res = "";
                for (i=1; i<=n_args; i++) {
                    c = colors[(i-1) % 4];
                    res = res "<code><font color=\"" c "\">" arr[i] "</font></code>";
                    if (i < n_args) res = res "<br>";
                }
                return res;
            }

            BEGIN { 
                inspect_out = ""; class_out = ""; sig_out = ""; met_out = "";
                last_doc = "";
            }

            # Capture doc comments
            /^[ \t]*##/ { 
                # If it is a class doc (at start of file), we ignore it here
                if (NR > 5) {
                    sub(/^[ \t]*##[ \t]*/, ""); 
                    last_doc = $0; 
                    next; 
                }
            }

            # 1. Export Groups
            /^@export_(group|category)\(/ {
                split($0, a, "\"");
                inspect_out = inspect_out "| **--- " toupper(a[2]) " ---** | | | |\n";
                last_doc = ""; next;
            }

            # 2. Variables
            /var / {
                if (last_doc == "") next;
                line = $0;
                split(line, parts, "var "); split(parts[2], name_part, " ");
                split(name_part[1], name_final, ":"); n = name_final[1];
                t = "Variant";
                if (index(line, ":") > 0) { 
                    split(substr(line, index(line, ":")+1), tp, " "); 
                    split(tp[1], tf, "="); t = tf[1]; 
                }
                dv = "-";
                if (index(line, "=") > 0) {
                    split(line, vp, "="); dv = vp[2];
                    sub(/^[ \t]*/, "", dv); sub(/[ \t]*[:;][ \t]*$/, "", dv); sub(/[ \t]*$/, "", dv);
                }
                row = "| **" n "** | " bt_code t bt_code " | " bt_code dv bt_code " | " last_doc " |\n";
                if (index(line, "@export") > 0) inspect_out = inspect_out row;
                else class_out = class_out row;
                last_doc = "";
            }

            # 3. Signals
            /signal / {
                if (last_doc == "") next;
                code = $0; sub(/^[ \t]*signal /, "", code); sub(/[ \t]*$/, "", code);
                name = code; args = "-";
                if(index(code, "(") > 0) {
                    split(code, arr, "("); name = arr[1]; raw_args = arr[2]; sub(/\).*/, "", raw_args);
                    args = colorize(raw_args);
                }
                sig_out = sig_out "| **" name "** | " args " | " last_doc " |\n";
                last_doc = "";
            }

            # 4. Methods
            /func / {
                if (last_doc == "") { next; }
                code = $0; sub(/^[ \t]*func /, "", code); sub(/[ \t]*$/, "", code);
                split(code, parts, "("); name = parts[1];
                if(index(name, "_") == 1) { last_doc = ""; next; }
                
                raw_args = parts[2]; sub(/\).*/, "", raw_args);
                args = (raw_args == "") ? "-" : colorize(raw_args);
                
                ret = "void"; 
                if(index(code, "->") > 0) { 
                    split(code, c, "->"); ret = c[2]; 
                    sub(/[ \t]*[:;][ \t]*$/, "", ret); gsub(/[ \t]+/, "", ret); 
                }
                met_out = met_out "| **" name "()** | " args " | " bt_code ret bt_code " | " last_doc " |\n";
                last_doc = "";
            }

            # Reset doc if we hit a blank line or other code
            /^[ \t]*$/ { last_doc = ""; }

            END {
                if (inspect_out != "") {
                    print "### ⚙️ Inspector Variables\n| Property | Type | Default | Description |\n| :--- | :--- | :--- | :--- |";
                    printf "%s\n", inspect_out;
                }
                if (class_out != "") {
                    print "### 💾 Class Variables\n| Property | Type | Default | Description |\n| :--- | :--- | :--- | :--- |";
                    printf "%s\n", class_out;
                }
                if (sig_out != "") {
                    print "### 🔔 Signals\n| Signal | Arguments | Description |\n| :--- | :--- | :--- |";
                    printf "%s\n", sig_out;
                }
                if (met_out != "") {
                    print "### 🛠️ Methods\n| Method | Arguments | Returns | Description |\n| :--- | :--- | :--- | :--- |";
                    printf "%s\n", met_out;
                }
            }' "$script"
            echo -e "---\n"
        } >> "$BODY_CONTENT"
    done

    cat "$BODY_CONTENT" >> "$TEMP_DOC"; rm -f "$BODY_CONTENT"
    
    if [ ! -f "$DOC_FILE" ] || ! diff <(sed '2d' "$TEMP_DOC") <(sed '2d' "$DOC_FILE") > /dev/null; then
        mv "$TEMP_DOC" "$DOC_FILE"
        cd "$PROJECT_ROOT/$addon_path"
        git add . && git commit -m "docs: fixed unified stateful parser" && super-git-push
        ((UPDATED_COUNT++))
    else
        rm -f "$TEMP_DOC"
    fi
    cd "$PROJECT_ROOT"
done
echo "✅ Finished! $UPDATED_COUNT addons updated."
