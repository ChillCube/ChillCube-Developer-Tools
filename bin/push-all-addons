#!/usr/bin/env bash

# --- Chillcube Bulk Addon Pusher & Doc Generator (V2) ---
# NO 'set -e' here so we don't stop on single addon failures.

if [ ! -d "addons" ]; then
    echo "❌ No addons/ directory found."
    exit 1
fi

PROJECT_ROOT=$(pwd)
echo "🧊 Starting bulk process..."

# Use a standard loop for better compatibility
for addon_path in addons/*; do
    [ -d "$addon_path" ] || continue # Skip if not a directory
    
    addon_name=$(basename "$addon_path")
    
    if [ -d "$addon_path/.git" ]; then
        echo "--------------------------------------------------"
        echo "🚀 Addon: $addon_name"
        
        # 1. GENERATE DOCUMENTATION
        TEMP_XML="$PROJECT_ROOT/temp_xml_$addon_name"
        TEMP_OUT="$PROJECT_ROOT/docs_out_$addon_name"
        mkdir -p "$TEMP_XML" "$TEMP_OUT"

        echo "📝 Extracting Godot 4 XML..."
        # We use the absolute path for doctool but res:// for the scan
        godot --headless --doctool "$TEMP_XML" --no-docbase --gdscript-docs "res://addons/$addon_name"
        
        # Check if we got any XML files
        if [ "$(ls -A "$TEMP_XML")" ]; then
            echo "📝 Converting to DOCUMENTATION.md..."
            godocs construct jinja --format md "$TEMP_XML" "$TEMP_OUT"
            
            # Stitch into the addon folder
            DOC_FILE="$PROJECT_ROOT/$addon_path/DOCUMENTATION.md"
            echo "# $addon_name API Reference" > "$DOC_FILE"
            echo -e "Generated: $(date)\n\n---\n" >> "$DOC_FILE"
            
            for f in "$TEMP_OUT"/*.md; do
                if [[ $(basename "$f") != "index.md" ]]; then
                    cat "$f" >> "$DOC_FILE"
                    echo -e "\n\n---\n" >> "$DOC_FILE"
                fi
            done
        else
            echo "⚠️  No ## doc-comments found. Skipping docs."
        fi

        # 2. GIT OPERATIONS
        cd "$PROJECT_ROOT/$addon_path"
        
        # Stage the new doc if it exists
        if [ -f "DOCUMENTATION.md" ]; then
            git add DOCUMENTATION.md
        fi

        # Check for any changes to commit
        if ! git diff-index --quiet HEAD; then
            echo "💾 Committing changes..."
            git commit -m "docs: update auto-generated documentation"
        else
            echo "ℹ️  No changes to commit."
        fi

        # 3. PUSH
        echo "📤 Running push..."
        if command -v super-git-push >/dev/null 2>&1; then
            super-git-push || echo "❌ Push failed for $addon_name"
        else
            "$PROJECT_ROOT/bin/super-git-push" || echo "❌ Push failed for $addon_name"
        fi

        # Cleanup & Return
        cd "$PROJECT_ROOT"
        rm -rf "$TEMP_XML" "$TEMP_OUT"
        echo "✅ Finished $addon_name"
        
    else
        echo "⏭️  Skipping $addon_name (No .git)"
    fi
done

echo "--------------------------------------------------"
echo "🎉 All addons processed."
