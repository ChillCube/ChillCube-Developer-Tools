#!/usr/bin/env bash

# --- Chillcube Global Link Resolver & Doc Generator ---
PROJECT_ROOT=$(pwd)
declare -A CLASS_TO_REPO  # Map: ClassName -> GitHub URL
declare -A CLASS_TO_ADDON # Map: ClassName -> Addon Folder Name

echo "🔍 Indexing Project & Dependencies..."

# --- 1. PRE-SCAN: Map all classes to their respective GitHub Repos ---
for addon_path in addons/*; do
    [ -d "$addon_path/.git" ] || continue
    addon_folder=$(basename "$addon_path")
    
    # Get the GitHub URL (and clean it to a standard https format)
    REPO_URL=$(git -C "$addon_path" remote get-url origin 2>/dev/null | sed 's/\.git$//' | sed 's/git@github\.com:/https:\/\/github\.com\//')
    
    # Find all class_names in this specific addon
    while read -r cname; do
        if [ -n "$cname" ]; then
            CLASS_TO_REPO["$cname"]="$REPO_URL"
            CLASS_TO_ADDON["$cname"]="$addon_folder"
        fi
    done < <(grep -r "class_name" "$addon_path" --include="*.gd" | sed 's/.*class_name //; s/[ \t]*$//; s/ .*//')
done

# --- 2. GENERATION LOOP ---
for addon_path in addons/*; do
    [ -d "$addon_path/.git" ] || continue
    addon_folder=$(basename "$addon_path")
    echo "🚀 Processing: $addon_folder"

    DOC_FILE="$addon_path/DOCUMENTATION.md"
    TEMP_DOC=$(mktemp)
    
    # Header logic (metadata, name, etc)
    echo "# $(basename "$addon_path") API Reference" > "$TEMP_DOC"
    echo -e "Generated: $(date +'%Y-%m-%d')\n---\n" >> "$TEMP_DOC"

    mapfile -t SCRIPTS < <(find "$addon_path" -name "*.gd")

    for script in "${SCRIPTS[@]}"; do
        C_NAME=$(grep "class_name" "$script" | sed 's/class_name //' | sed 's/[ \t]*$//' | sed 's/ .*//')
        [ -z "$C_NAME" ] && C_NAME=$(basename "$script" .gd)

        # --- SMART LINK RESOLVER ---
        RAW_EXT=$(grep "^extends " "$script" | sed 's/extends //' | sed 's/[ \t]*$//' | sed 's/ .*//')
        [ -z "$RAW_EXT" ] && RAW_EXT="Object"

        if [[ -n "${CLASS_TO_REPO[$RAW_EXT]}" ]]; then
            # Is it internal or a dependency?
            if [[ "${CLASS_TO_ADDON[$RAW_EXT]}" == "$addon_folder" ]]; then
                EXT_LINK="[\`$RAW_EXT\`](#class-$RAW_EXT)"
            else
                # External dependency: Links to the GitHub Documentation file of that repo
                EXT_LINK="[\`$RAW_EXT\`](${CLASS_TO_REPO[$RAW_EXT]}/blob/main/DOCUMENTATION.md#class-$RAW_EXT)"
            fi
        elif [[ "$RAW_EXT" =~ ^[A-Z] ]] && [[ ! "$RAW_EXT" =~ [./\"] ]]; then
            # Godot Engine Class
            EXT_LINK="[\`$RAW_EXT\`](https://docs.godotengine.org/en/stable/classes/class_${RAW_EXT,,}.html)"
        else
            EXT_LINK="\`$RAW_EXT\`"
        fi

        # [AWK Logic for Properties, Signals, Methods remains the same]
        # ... (Insert the stable AWK blocks from previous steps here) ...

        # Append to Temp Doc
        echo -e "## Class: $C_NAME" >> "$TEMP_DOC"
        echo -e "**Inherits:** $EXT_LINK\n" >> "$TEMP_DOC"
        # ... (Append Table Data) ...
        echo -e "\n---\n" >> "$TEMP_DOC"
    done

    # --- 3. COMMIT & PUSH ---
    mv "$TEMP_DOC" "$DOC_FILE"
    cd "$addon_path"
    git add DOCUMENTATION.md
    git commit -m "docs: updated api with cross-repo dependency links"
    git push origin main
    cd "$PROJECT_ROOT"
done
