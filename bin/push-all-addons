#!/usr/bin/env bash

# --- Chillcube Universal Doc & Registry Engine (v6.1) ---
PROJECT_ROOT=$(pwd)
UPDATED_COUNT=0

echo "🔍 Indexing Project-Wide Class Map..."

# --- 1. GENERATION LOOP ---
for addon_path in addons/*; do
    [ -d "$addon_path/.git" ] || continue
    addon_folder=$(basename "$addon_path")
    echo "--------------------------------------------------"
    echo "🚀 Processing: $addon_folder"

    DOC_FILE="$addon_path/DOCUMENTATION.md"
    TEMP_DOC=$(mktemp)
    
    CFG_FILE="$addon_path/plugin.cfg"
    [ ! -f "$CFG_FILE" ] && continue
    A_NAME=$(grep "name" "$CFG_FILE" 2>/dev/null | head -n 1 | sed 's/.*"\(.*\)".*/\1/')
    A_DESC=$(grep "description" "$CFG_FILE" 2>/dev/null | head -n 1 | sed 's/.*"\(.*\)".*/\1/')
    [ -z "$A_DESC" ] && A_DESC="Godot Addon"
    
    echo "# $A_NAME API Reference" > "$TEMP_DOC"
    echo -e "Generated: $(date +'%Y-%m-%d')\n\n$A_DESC\n" >> "$TEMP_DOC"
    BODY_CONTENT=$(mktemp)
    mapfile -t SCRIPTS < <(find "$addon_path" -name "*.gd")

    for script in "${SCRIPTS[@]}"; do
        C_NAME=$(grep "class_name" "$script" | sed 's/class_name //' | sed 's/ .*//'); [ -z "$C_NAME" ] && C_NAME=$(basename "$script" .gd)
        {
            echo -e "## Class: $C_NAME\n"
            awk '/^##/ { print substr($0, 4); next } /^[^#]/ { exit }' "$script"
            echo ""
            
            # --- GROUPED EXPORT PROPERTIES ---
            echo "### ⚙️ Inspector Variables"
            awk -v bt="`" '
            BEGIN { printf "| Property | Type | Default | Description |\n| :--- | :--- | :--- | :--- |\n"; }
            /^@export_(group|category)\(/ {
                split($0, a, "\"");
                printf "| **--- %s ---** | | | |\n", toupper(a[2]);
                next;
            }
            /^@export[ \t\n]/ || /^@export_.*var/ {
                line = $0; split(line, p, "##"); d = (p[2] != "") ? p[2] : "-";
                sub(/^[ \t]*/, "", d); split(line, parts, "var ");
                split(parts[2], name_part, " "); split(name_part[1], name_final, ":");
                n = name_final[1]; t = "Variant";
                if (index(line, ":") > 0) { 
                    split(substr(line, index(line, ":")+1), tp, " "); 
                    split(tp[1], tf, "="); t = tf[1]; 
                }
                dv = "-";
                if (index(line, "=") > 0) {
                    split(line, vp, "="); dv = vp[2];
                    sub(/^[ \t]*/, "", dv); sub(/[ \t]*[:;][ \t]*$/, "", dv);
                }
                if (n != "") printf "| %s | %s%s%s | %s%s%s | %s |\n", n, bt, t, bt, bt, dv, bt, d;
            }' "$script"
            echo ""

            # --- SIGNALS & METHODS (With Color Rotation) ---
            # Using a custom AWK function to handle the "rainbow" effect
            awk -v bt="`" '
            function colorize(raw) {
                if (raw == "" || raw == "-") return "-";
                split(raw, arr, ",[ \t]*");
                colors[0]="#00f2ff"; colors[1]="#ff9d00"; colors[2]="#ff00ff"; colors[3]="#00ff88";
                result = "";
                for (i=1; i<=length(arr); i++) {
                    c = colors[(i-1) % 4];
                    result = result "<code><font color=\"" c "\">" arr[i] "</font></code>";
                    if (i < length(arr)) result = result "<br>";
                }
                return result;
            }
            # Signal Logic
            index($0, "signal") > 0 && index($0, "##") > 0 {
                split($0,p,"##"); d=p[2]; code=p[1];
                sub(/^[ \t]*signal /, "", code); sub(/[ \t]*$/, "", code);
                name=code; raw_args="";
                if(index(code, "(") > 0) {
                    split(code, arr, "("); name=arr[1]; raw_args=arr[2]; sub(/\).*/, "", raw_args);
                }
                printf("SIGNAL|%s|%s|%s\n", name, colorize(raw_args), d);
            }
            # Method Logic
            index($0, "func") > 0 && index($0, "##") > 0 {
                split($0,p,"##"); d=p[2]; code=p[1];
                sub(/^[ \t]*func /, "", code); sub(/[ \t]*$/, "", code);
                split(code, parts, "("); name=parts[1];
                if(index(name, "_") == 1) next;
                raw_args=parts[2]; sub(/\).*/, "", raw_args);
                ret="void"; 
                if(index(code, "->") > 0) { split(code, c, "->"); ret=c[2]; sub(/[ \t]*[:;][ \t]*$/, "", ret); gsub(/[ \t]+/, "", ret); }
                printf("METHOD|%s|%s|%s|%s\n", name, colorize(raw_args), ret, d);
            }' "$script" > awk_out.tmp

            # Format the temp output into tables
            if grep -q "SIGNAL" awk_out.tmp; then
                echo -e "### 🔔 Signals\n| Signal | Arguments | Description |\n| :--- | :--- | :--- |"
                grep "SIGNAL" awk_out.tmp | sed 's/SIGNAL|//' | awk -F'|' '{printf "| **%s** | %s | %s |\n", $1, $2, $3}'
                echo ""
            fi
            if grep -q "METHOD" awk_out.tmp; then
                echo -e "### 🛠️ Methods\n| Method | Arguments | Returns | Description |\n| :--- | :--- | :--- | :--- |"
                grep "METHOD" awk_out.tmp | sed 's/METHOD|//' | awk -F'|' -v bt="`" '{printf "| **%s()** | %s | %s%s%s | %s |\n", $1, $2, bt, $3, bt, $4}'
                echo ""
            fi
            rm awk_out.tmp
            echo -e "---\n"
        } >> "$BODY_CONTENT"
    done

    cat "$BODY_CONTENT" >> "$TEMP_DOC"; rm -f "$BODY_CONTENT"
    
    # 5. FINAL SYNC
    if [ ! -f "$DOC_FILE" ] || ! diff <(sed '2d' "$TEMP_DOC") <(sed '2d' "$DOC_FILE") > /dev/null; then
        mv "$TEMP_DOC" "$DOC_FILE"
        cd "$PROJECT_ROOT/$addon_path"
        git add . && git commit -m "docs: rainbow arguments and improved grouping" && super-git-push
        ((UPDATED_COUNT++))
    else
        rm -f "$TEMP_DOC"
    fi
    cd "$PROJECT_ROOT"
done
echo "✅ Finished! $UPDATED_COUNT addons updated."
