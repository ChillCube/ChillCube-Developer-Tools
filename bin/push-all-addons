#!/usr/bin/env bash

# --- Chillcube Bulk Addon Pusher & Doc Generator (V3) ---

VENV_PATH="/tmp/chillcube_docs_env"
if ! command -v godocs &> /dev/null; then
    if [ ! -d "$VENV_PATH" ]; then
        python3 -m venv "$VENV_PATH"
        "$VENV_PATH/bin/pip" install godocs godocs-jinja --quiet
    fi
    export PATH="$VENV_PATH/bin:$PATH"
fi

PROJECT_ROOT=$(pwd)

for addon_path in addons/*; do
    [ -d "$addon_path/.git" ] || continue
    addon_name=$(basename "$addon_path")
    
    echo "--------------------------------------------------"
    echo "đźš€ Addon: $addon_name"

    # Fix indentation for Godot Parser
    find "$addon_path" -name "*.gd" -exec sed -i 's/    /\t/g' {} +

    TEMP_XML="$PROJECT_ROOT/temp_xml_$addon_name"
    TEMP_OUT="$PROJECT_ROOT/docs_out_$addon_name"
    mkdir -p "$TEMP_XML" "$TEMP_OUT"

    godot --headless --doctool "$TEMP_XML" --no-docbase --gdscript-docs "res://addons/$addon_name"
    
    if [ "$(ls -A "$TEMP_XML" 2>/dev/null)" ]; then
        echo "đź“ť Reconstructing Documentation..."
        godocs construct jinja --format md "$TEMP_XML" "$TEMP_OUT"
        
        DOC_FILE="$PROJECT_ROOT/$addon_path/DOCUMENTATION.md"
        
        # 1. Start with the Header
        echo "# $addon_name API Reference" > "$DOC_FILE"
        echo -e "Generated on: $(date)\n\n---\n" >> "$DOC_FILE"

        for f in "$TEMP_OUT"/*.md; do
            [ -e "$f" ] || continue
            [[ $(basename "$f") == "index.md" ]] && continue
            
            # 2. Process the file using a simpler line-by-line approach
            cat "$f" | sed -E \
                -e 's/:ref:`[^<]* <([^>]*)>`/\1/g' \
                -e 's/\\//g' \
                -e '/^Inherits:/d' \
                -e '/^\.\. /d' \
                -e '/^[=-]+$/d' \
                -e '/^Description$/d' \
                -e '/^Class Reference$/d' \
                -e "/^$addon_name$/d" | \
            awk '
                BEGIN { body = "" }
                
                # Capture Signals
                /^[a-zA-Z0-9_]+\(.*\)$/ && !/`/ {
                    print "### " $0
                    print "**Event:** Signal\n"
                    next
                }

                # Capture Property Lines: `Type` Name = `Default`
                /^`[^`]+` [^` ]+/ {
                    split($0, a, "`")
                    type = a[2]
                    
                    # Split name and default
                    rest = a[3]
                    if (rest ~ /=/) {
                        split(rest, b, "=")
                        name = b[1]; gsub(/ /, "", name)
                        default_val = a[4]
                        
                        print "### " name
                        print "**Type:** " type
                        print "**Default:** " default_val "\n"
                    } else {
                        name = rest; gsub(/ /, "", name)
                        print "### " name
                        print "**Type:** " type "\n"
                    }
                    next
                }

                # Capture Method Lines: `Type` name(...)
                /^`[^`]+` [^` ]+\(.*\)$/ {
                    split($0, a, "`")
                    type = a[2]
                    sig = a[3]; sub(/^[ ]+/, "", sig)
                    
                    print "### " sig
                    print "**Returns:** " type "\n"
                    next
                }

                # Everything else is description text
                {
                    # Skip the weird table remnants
                    if ($0 ~ /header-rows/ || $0 ~ /\* -/ || $0 ~ /Index/) next
                    if (NF > 0) print $0 "\n"
                }
            ' >> "$DOC_FILE"
        done
        
        # 3. Clean up the Class Header (Make the first non-title line a ## Header)
        # We find the first word (Addon name) and turn it into ## AddonName
        sed -i "0,/^$addon_name/s/^$addon_name/## $addon_name/" "$DOC_FILE"
    fi

    # 4. GIT SYNC
    cd "$PROJECT_ROOT/$addon_path"
    if [ -f "DOCUMENTATION.md" ]; then
        git add DOCUMENTATION.md
        if ! git diff-index --quiet HEAD; then
            git commit -m "docs: auto-generate documentation"
            if command -v super-git-push >/dev/null 2>&1; then
                super-git-push
            else
                "$PROJECT_ROOT/bin/super-git-push"
            fi
        fi
    fi

    cd "$PROJECT_ROOT"
    rm -rf "$TEMP_XML" "$TEMP_OUT"
    echo "âś… Finished $addon_name"
done
