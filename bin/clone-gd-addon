#!/usr/bin/env bash

# --- Chillcube Universal Bootstrapper (v2.1 - The "Elevator") ---
REPO_URL=$1

if [ -z "$REPO_URL" ]; then
    echo "Usage: clone-gd-addon <git_url>"
    exit 1
fi

# 1. Setup Environment
mkdir -p addons
TEMP_CLONE=".tmp_addon_$(date +%s)" # Unique temp folder
rm -rf "$TEMP_CLONE"

# 2. Clone to Temp (using a full clone to ensure we get all metadata)
echo "📥 Cloning: $REPO_URL..."
git clone --quiet "$REPO_URL" "$TEMP_CLONE" || { echo "❌ Clone failed"; exit 1; }

# 3. The "Elevation" Logic
INTERNAL_ADDONS_DIR="$TEMP_CLONE/addons"

if [ -d "$INTERNAL_ADDONS_DIR" ]; then
    echo "📂 Detected /addons folder. Elevating contents..."
    
    for d in "$INTERNAL_ADDONS_DIR"/*/; do
        [ -d "$d" ] || continue
        ADDON_NAME=$(basename "$d")
        TARGET_DIR="addons/$ADDON_NAME"
        
        echo "📦 Installing: $ADDON_NAME"
        rm -rf "$TARGET_DIR"
        mv "$d" "$TARGET_DIR"
        
        # --- CRITICAL: Restore Git Identity ---
        pushd "$TARGET_DIR" > /dev/null
        git init -q
        git remote add origin "$REPO_URL"
        # Optional: fetch to link history, though this increases disk usage
        # git fetch --depth 1 origin main 
        popd > /dev/null
    done
else
    # FALLBACK: Repo is already flat
    ADDON_NAME=$(basename "$REPO_URL" .git)
    TARGET_DIR="addons/$ADDON_NAME"
    
    echo "📦 Flat repo detected: $ADDON_NAME"
    rm -rf "$TARGET_DIR"
    
    # Move the entire temp clone folder (including .git) to the destination
    mv "$TEMP_CLONE" "$TARGET_DIR"
fi

# 4. Cleanup (Only if temp folder still exists)
[ -d "$TEMP_CLONE" ] && rm -rf "$TEMP_CLONE"

# 5. Recursive Dependency Check
# Now we scan only the folders we just added/updated for new dependencies
find addons -maxdepth 2 -name "DEPENDENCIES.txt" | while read -r DEP_FILE; do
    while read -r dep_url || [ -n "$dep_url" ]; do
        [[ -z "$dep_url" || "$dep_url" =~ ^# ]] && continue
        
        DEP_NAME=$(basename "$dep_url" .git)
        if [ ! -d "addons/$DEP_NAME" ]; then
            echo "🔗 New dependency found in $DEP_FILE: $DEP_NAME"
            $0 "$dep_url" # Recursive call
        fi
    done < "$DEP_FILE"
done

echo "✅ Done! Structure synchronized."
