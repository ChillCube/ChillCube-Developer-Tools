#!/usr/bin/env bash
set -e

echo "🧊 Chillcube Addon Initializer"
echo "--------------------------------------------------"

# 1. Collect Project Info
read -p "🏷️  Addon Name: " ADDON_NAME
read -p "📝 Description: " ADDON_DESC
read -p "👤 Author Name: " AUTHOR_NAME
read -p "📦 Dependencies (comma separated): " DEPS
YEAR=$(date +%Y)

# Safe folder name (e.g., "Chill Inventory") -> "chill-inventory"
FOLDER_NAME=$(echo "$ADDON_NAME" | tr '[:upper:]' '[:lower:]' | tr ' ' '-')

# 2. Create Directory Structure
echo "📂 Creating directory structure..."
mkdir -p "$FOLDER_NAME/addons/$FOLDER_NAME"
cd "$FOLDER_NAME"

# 3. Initialize Git
git init -q

# 4. Create DEPENDENCIES.txt (Inside the addon folder)
echo "📄 Generating DEPENDENCIES.txt..."
{
    echo "🧊 Chillcube Dependency Manifest"
    echo "Project: $ADDON_NAME"
    echo "--------------------------------------------------"
    if [ -z "$DEPS" ]; then
        echo "None"
    else
        echo "$DEPS" | tr ',' '\n' | sed 's/^[[:space:]]*//; s/^[[:space:]]*/ - /'
    fi
} > "addons/$FOLDER_NAME/DEPENDENCIES.txt"

# 5. Create Godot plugin.cfg
# Even if it's just a library, this lets users see the version/author in Godot
echo "⚙️  Generating plugin.cfg..."
cat <<EOF > "addons/$FOLDER_NAME/plugin.cfg"
[plugin]
name="$ADDON_NAME"
description="$ADDON_DESC"
author="$AUTHOR_NAME"
version="0.1.0"
script=""
EOF

# 6. Fetch README and License
# Replace with your actual repo raw URL
TEMPLATE_URL="https://raw.githubusercontent.com/ChillCube/ChillCube-Developer-Tools/main/templates/README_TEMPLATE.md"

echo "📥 Fetching templates..."
curl -s "$TEMPLATE_URL" -o README.md || echo "⚠️  README template not found; created empty file."

if [ -f README.md ]; then
    sed -i "s/{{NAME}}/$ADDON_NAME/g" README.md
    sed -i "s/{{DESC}}/$ADDON_DESC/g" README.md
    sed -i "s/{{AUTHOR}}/$AUTHOR_NAME/g" README.md
    sed -i "s/{{YEAR}}/$YEAR/g" README.md
fi

echo "⚖️  Applying BSL-1.1 License..."
curl -s "https://raw.githubusercontent.com/MariaDBCorporation/BSL-1.1/master/BSL-1.1.txt" -o LICENSE

# 7. Finalize
echo "--------------------------------------------------"
echo "✅ Done! Addon initialized in: $FOLDER_NAME"
echo "🚀 Next step: cd $FOLDER_NAME and open in Godot."
